<odoo>
    <data>
      <record id="product_product_pvp" model="ir.ui.view">
        <field name="name">product.product.pvp</field>
        <field name="inherit_id" ref="product.product_variant_easy_edit_view"/>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
          <field name="standard_price" position="after">
                <label for="product_product_pvp" string="PVP"/>
                <field name="product_product_pvp" string="PVP" widget="monetary"/>
          </field>
        </field>
      </record>

      <record id="product_product_pvp" model="ir.ui.view">
        <field name="name">product.product.pvp</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
          <field name="standard_price" position="after">
                <label for="product_product_pvp" string="PVP"/>
                <field name="product_product_pvp" string="PVP" widget="monetary"/>
          </field>
        </field>
      </record>
    </data>
  </odoo>