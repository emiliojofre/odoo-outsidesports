<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="inherit_address" inherit_id="website_sale.address" name="Add city in address">
        <!-- Campos a ocultar  -->
        <xpath expr="//div[contains(@t-attf-class, 'mb-3')][contains(@t-attf-class, 'div_street2')]" position="attributes">
            <attribute name="t-attf-style">display: none;</attribute>
        </xpath>

        <xpath expr="//div[contains(@t-attf-class, 'mb-3')][contains(@t-attf-class, 'div_state')]" position="replace">
        </xpath>
        
        <xpath expr="//div[contains(@t-attf-class, 'mb-3')][contains(@t-attf-class, 'div_city')]" position="replace">
        </xpath>

        <!-- Campos a mover de posición -->
        <xpath expr="//div[contains(@t-attf-class, 'mb-3')][contains(@t-attf-class, 'div_country')]" position="after">
            <div t-attf-class="mb-3 #{error.get('state_id') and 'o_has_error' or ''} col-lg-6 div_state">
                <label class="col-form-label" for="state_id">Región</label>
                <select name="state_id" t-attf-class="form-select #{error.get('state_id') and 'is-invalid' or ''}" data-init="1">
                    <option value="">Región ...</option>
                    <t t-foreach="country_states" t-as="s">
                        <t t-if="s.id in country.state_ids.ids">
                            <option t-att-value="s.id" t-att-selected="s.id == ('state_id' in checkout and country and checkout['state_id'] != '' and int(checkout['state_id']))">
                                <t t-esc="s.name" />
                            </option>
                        </t>
                    </t>
                </select>
            </div>
            <div class="w-100"/>
            <div t-attf-class="mb-3 #{error.get('city') and 'o_has_error' or ''} col-md-8 div_city">
                <label class="col-form-label" for="city">Comuna</label>
                <select name="city" class="form-select" t-attf-class="form-control #{error.get('city') and 'is-invalid' or ''}" t-att-mode="mode[1]">
                    <option value="">Comuna...</option>
                    <t t-foreach="cities" t-as="city">
                        <option t-att-value="city.id" t-att-selected="('city' in checkout and checkout['city'] == city.id) or -1">
                            <t t-esc="city.name" />
                        </option>
                    </t>
                </select>
            </div>
        </xpath>

    </template>

    <template id="inherit_address_my_portal" inherit_id="portal.portal_my_details_fields" name="My Portal Address">
        <xpath expr="//div[input[@name='city']]" position="replace">
            <div t-attf-class="mb-3 #{error.get('city') and 'o_has_error' or ''} col-xl-6">
                <label class="col-form-label" for="city">Comuna</label>
                <!-- <input type="text" name="city" t-attf-class="form-control #{error.get('city') and 'is-invalid' or ''}" t-att-value="city or partner.city" /> -->
                <select name="city" class="form-select" t-attf-class="form-control #{error.get('city') and 'is-invalid' or ''}" t-att-mode="mode[1]">
                    <option value="">Comuna...</option>
                    <t t-foreach="cities" t-as="ciudad">
                        <option t-att-value="city or partner.city" t-att-selected="ciudad.id == int(city.id) if city else city.id == partner.city.id">
                            <t t-esc="ciudad.name" />
                        </option>
                    </t>
                </select>
            </div>
        </xpath>
    </template>
</odoo>