    <template id="stock_report_delivery_aggregated_move_lines_inherit" inherit_id="stock.stock_report_delivery_aggregated_move_lines" priority="30">  
        <xpath expr="//tr[@t-foreach='aggregated_lines']/td[1]" position="replace">
            <td>
                <span t-esc="aggregated_lines[line]['product'].default_code"/>
            </td>
            <td>
                <span t-esc="aggregated_lines[line]['product'].name"/>
                <t t-set="variant_names" t-value="[]"/>
                <t t-foreach="aggregated_lines[line]['product'].product_template_variant_value_ids" t-as="variant_value">
                    <t t-set="variant_names" t-value="variant_names + [variant_value.name]"/>
                </t>
                <span>
                  <t t-esc="', '.join(variant_names)"/>
                </span>
            </td>
        </xpath>
        <xpath expr="//td[@name='move_line_aggregated_qty_ordered']" position="replace">
            <td class="text-center" name="move_line_aggregated_qty_ordered">
                <span t-esc="aggregated_lines[line]['qty_ordered']" t-options="{'widget': 'float', 'decimal_precision': 'Product Unit of Measure'}"/>
            </td>
        </xpath>
        <xpath expr="//td[@name='move_line_aggregated_qty_done']" position="replace">
            <td class="text-center" name="move_line_aggregated_qty_done">
                <t t-if="aggregated_lines[line]['qty_done']">
                    <span t-esc="aggregated_lines[line]['product'].qty_available" t-options="{'widget': 'float', 'decimal_precision': 'Product Unit of Measure'}"/>
                </t>
            </td>
        </xpath>
    </template>
    

    <!-- Herencia de purchase.report_purchasequotation -->
    <template id="delivery_guide_document_inherit"
        inherit_id="l10n_cl_edi_stock.delivery_guide_document" priority="30">
        <xpath expr="//th[@name='th_code']" position="replace">
            <th name="th_sku">
                <strong>SKU</strong>
            </th>
        </xpath>
        <xpath expr="//th[@name='th_product']" position="replace">
            <th name="th_product">
                <strong>DESCRIPCIÓN</strong>
            </th>
        </xpath>
        <xpath expr="//th[@groups='uom.group_uom']" position="replace">
        </xpath>
        <xpath expr="//td[@groups='uom.group_uom']" position="replace">
        </xpath>
    </template>

</odoo>