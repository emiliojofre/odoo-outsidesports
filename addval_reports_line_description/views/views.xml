<!-- report_templates.xml -->
<odoo>
    <!-- Herencia de account.report_invoice_document -->
    <template id="report_invoice_with_payments_inherit" inherit_id="account.report_invoice_document">
        <xpath expr="//th[@name='th_description']" position="before">
            <th name="th_sku">
                <strong>SKU</strong>
            </th>
        </xpath>
        <xpath expr="//td[span[@t-field='line.name']]" position="replace">
            <td>
                <span t-field="line.product_id.default_code" t-options="{'widget': 'text'}" />
            </td>
            <td>
                <span t-field="line.product_id.name" t-options="{'widget': 'text'}" />
            </td>
        </xpath>
    </template>

    <!-- Herencia de purchase.report_purchaseorder -->
    <template id="report_purchaseorder_document_inherit"
        inherit_id="purchase.report_purchaseorder_document">
        <xpath expr="//td[span[@t-field='line.name']]" position="replace">
            <td>
                <span t-field="line.product_id.name" />
            </td>
        </xpath>
    </template>

    <!-- Herencia de purchase.report_purchasequotation -->
    <template id="report_purchasequotation_document_inherit"
        inherit_id="purchase.report_purchasequotation_document" priority="30">
        <xpath expr="//td[span[@t-field='order_line.name']]" position="replace">
            <td>
                <span t-field="order_line.product_id.name" />
            </td>
        </xpath>
    </template>

    <!-- Herencia de sale.report_saleorder -->
    <template id="report_saleorder_document_inherit" inherit_id="sale.report_saleorder_document">
        <xpath expr="//th[@name='th_description']]" position="before">
            <th name="th_default_code" class="text-start">SKU</th>
        </xpath>
        <xpath expr="//td[span[@t-field='line.name']]" position="replace">
            <td>
                <span t-field="line.product_id.default_code" />
            </td>
            <td>
                <span t-field="line.product_id.name" />
                <t t-foreach="line.product_id.product_template_variant_value_ids" t-as="variant_value">
                    <p>, </p>
                    <span t-esc="variant_value.name" />
                </t>
            </td>
        </xpath>
        <xpath expr="//td[@name='td_quantity']]" position="replace">
            <td name="td_quantity" class="text-end">
                <span t-field="line.product_uom_qty"/>
            </td>
        </xpath>

        <xpath expr="//th[@name='th_taxes']]" position="replace">
        </xpath>
        
        <xpath expr="//td[@name='td_taxes']]" position="replace">
        </xpath>
    </template>
    
    <!-- Herencia de stock.report_delivery_document -->
    <template id="report_delivery_document_inherit" inherit_id="stock.report_delivery_document" priority="30">
        <xpath expr="//th[@name='th_sm_product']" position="before">
            <th>
                <strong>SKU</strong>
            </th>
        </xpath>
        <xpath expr="//table[@name='stock_move_table']/tbody/tr[1]/td[1]" position="replace">
            <td>
                <span t-field="move.product_id.default_code" />
            </td>
            <td>
                <span t-field="move.product_id.name" />
                <t t-foreach="move.product_id.product_template_variant_value_ids" t-as="variant_value">
                    <p>, </p>
                    <span t-esc="variant_value.name" />
                </t>
            </td>
        </xpath>

        <xpath expr="//th[@name='th_sm_quantity']" position="replace">
            <th>
                <strong>STOCK A MANO</strong>
            </th>
        </xpath>

        <xpath expr="//table[@name='stock_move_table']/tbody/tr[1]/td[2]" position="replace">
            <td>
                <span t-field="move.product_uom_qty"/>
            </td>
        </xpath>

        <xpath expr="//table[@name='stock_move_table']/tbody/tr[1]/td[3]" position="replace">
            <td>
                <span t-field="move.product_id.qty_available"/>
            </td>
        </xpath>
    </template>
    

    <!-- Herencia de purchase.report_purchasequotation -->
    <template id="delivery_guide_document_inherit"
        inherit_id="l10n_cl_edi_stock.delivery_guide_document" priority="30">
        <xpath expr="//th[@name='th_code']" position="replace">
            <th name="th_sku">
                <strong>SKU</strong>
            </th>
        </xpath>
        <xpath expr="//th[@name='th_product']" position="replace">
            <th name="th_product">
                <strong>DESCRIPCIÓN</strong>
            </th>
        </xpath>
        <xpath expr="//th[@groups='uom.group_uom']" position="replace">
        </xpath>
        <xpath expr="//td[@groups='uom.group_uom']" position="replace">
        </xpath>
    </template>

</odoo>