<odoo>
  <data>
    <record id="pricelist_item_brand" model="ir.ui.view">
      <field name="name">pricelist_item_brand.partner.expiration.rule</field>
      <field name="inherit_id" ref="product.product_pricelist_item_form_view"/>
      <field name="model">product.pricelist.item</field>
      <field name="arch" type="xml">
        <field name="applied_on" position="after">
          <field name="brand_id" options="{'no_create':1}" attrs="{ 'invisible':[('applied_on', '!=', '4_brand')], 'required':[('applied_on', '=', '4_brand')]}"/>
        </field>
      </field>
    </record>
  </data>
</odoo>