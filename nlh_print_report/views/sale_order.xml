<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="sale_order_line_form_inherit" model="ir.ui.view">
            <field name="name">sale.order.line.form.inherit</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='order_line']/tree/field[@name='price_unit']" position="after">
                    <field name="standard_price" readonly="False" invisible="1"/>
                    <field name="product_standard_price" widget="monetary"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>