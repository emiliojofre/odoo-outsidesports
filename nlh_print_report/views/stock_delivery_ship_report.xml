<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <template id="nlh_report_delivery_document" inherit_id="stock.report_delivery_document">
            <xpath expr="//div[hasclass('page')]" position="replace">
                <div class="page">
                    <div class="row" name="customer_address">
                        <div class="col-xs-4 pull-right">
                            <div>
                                <span><strong>Customer Address:</strong></span>
                            </div>
                            <t t-set="partner"
                               t-value="o.partner_id or (o.move_lines and o.move_lines[0].partner_id) or False"/>
                            <div t-if="partner" name="partner_header">
                                <div t-esc="partner"
                                     t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True}'/>
                            </div>
                        </div>
                    </div>
                    <h2>
                        <span t-field="o.name"/>
                    </h2>
                    <div class="clearfix" style="position:relative;padding:5px;">
                        <table style="position:relative" class="table table-condensed">
                            <thead>
                                <tr>
                                    <th t-if="o.origin"><strong>ORDEN (ORIGEN)</strong></th>
                                    <th name="td_sched_date_h">
                                        <strong>FECHA</strong>
                                    </th>
                                    <th t-if="o.state_tp"><strong>TRANSPORTE</strong></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td style="padding:1px!important;" t-if="o.origin">
                                        <span t-field="o.origin"/>
                                    </td>
                                    <td style="padding:1px!important;" name="td_sched_date">
                                        <t t-if="o.state == 'done'">
                                            <span t-field="o.date_done"/>
                                        </t>
                                        <t t-if="o.state != 'done'">
                                            <span t-field="o.scheduled_date"/>
                                        </t>
                                    </td>
                                    <td t-if="o.state_tp"><span t-field="o.state_tp"/></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="clearfix" style="position:relative">
                        <table style="position:relative" class="table table-condensed" t-if="o.state!='done'">
                            <thead>
                                <tr style="">
                                    <th><strong>Producto</strong></th>
                                    <th><strong>Cantidad</strong></th>
                                    <th><strong>Cantidad a Mano</strong></th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="lines" t-value="o.move_lines.filtered(lambda x: x.product_uom_qty)"/>
                                <tr t-foreach="lines" t-as="move">
                                    <td style="max-height:8px;line-height:14px!important;padding:1px!important;">
                                        <span t-field="move.product_id"/>
                                        <p t-if="o.picking_type_code == 'outgoing'">
                                            <span t-field="move.product_id.sudo().description_pickingout"/>
                                        </p>
                                        <p t-if="o.picking_type_code == 'incoming'">
                                            <span t-field="move.product_id.sudo().description_pickingin"/>
                                        </p>
                                    </td>
                                    <td style="max-height:8px;line-height:14px!important;padding:1px!important;">
                                        <span t-field="move.product_uom_qty"/>
                                        <span t-field="move.product_uom"/>
                                    </td>
                                    <td style="max-height:8px;line-height:14px!important;padding:1px!important;">
                                        <span t-field="move.product_id.sudo().qty_available"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="clearfix" style="position:relative;">
                        <table style="position:relative" class="table table-condensed"
                               t-if="o.move_line_ids and o.state=='done'">
                            <t t-set="has_serial_number" t-value="o.move_line_ids.mapped('lot_id')"
                               groups="stock.group_production_lot"/>
                            <thead>
                                <tr style="">
                                    <th><strong>Producto</strong></th>
                                    <th name="lot_serial" t-if="has_serial_number">
                                        Lot/Serial Number
                                    </th>
                                    <th class="text-center"><strong>Cantidad</strong></th>
                                    <th class="text-center"><strong>Cantidad a Mano</strong></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.move_line_ids" t-as="move_line">
                                    <td style="max-height:8px;line-height:14px!important;padding:1px!important;">
                                        <span t-field="move_line.product_id"/>
                                        <p t-if="o.picking_type_code == 'outgoing'">
                                            <span t-field="move_line.product_id.sudo().description_pickingout"/>
                                        </p>
                                        <p t-if="o.picking_type_code == 'incoming'">
                                            <span t-field="move_line.product_id.sudo().description_pickingin"/>
                                        </p>
                                    </td>
                                    <t t-if="has_serial_number">
                                        <td style="max-height:8px;line-height:14px!important;padding:1px!important;">
                                            <table width="100%">
                                                <tr>
                                                    <td style="max-height:8px;line-height:14px!important;padding:1px!important;">
                                                        <span t-field="move_line.lot_id"/>
                                                        <t t-if="not move_line.lot_id">
                                                            <span t-field="move_line.lot_name"/>
                                                        </t>
                                                    </td>
                                                    <td style="max-height:8px;line-height:14px!important;padding:1px!important;"
                                                        name="lot_qty">
                                                        <t t-if="move_line.product_qty">
                                                            <span t-field="move_line.product_qty"/>
                                                        </t>
                                                    </td>

                                                </tr>
                                            </table>
                                        </td>
                                    </t>
                                    <td style="max-height:8px;line-height:14px!important;padding:1px!important;"
                                        class="text-center">
                                        <span t-field="move_line.qty_done"/>
                                        <span t-field="move_line.product_uom_id"/>
                                    </td>

                                    <td style="max-height:8px;line-height:14px!important;padding:1px!important;"
                                        name="qty_available">
                                        <t t-if="move_line.product_id">
                                            <span t-field="move_line.product_id.qty_available"/>
                                        </t>
                                    </td>

                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <p t-if="o.backorder_id">
                        This shipment is a backorder of <t t-esc="o.backorder_id.name"/>.
                    </p>
                    <p>
                        <t t-if="o.search([('backorder_id', '=', o.id), ('state', 'not in', ['cancel', 'done'])])">
                            All items couldn't be shipped, the remaining ones will be shipped as soon as they become
                            available.
                        </t>
                    </p>
                </div>
            </xpath>
        </template>
    </data>
</odoo>