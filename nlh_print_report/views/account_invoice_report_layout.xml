<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="nlh_account_invoice_report" inherit_id="l10n_cl_fe.dte_external_layout">
            <xpath expr="//div[hasclass('page')]" position="replace">
                <t t-set="count" t-value="0"/>
                <div class="page" style="position:relative; top:100px;">
                    <div class="oe_structure"/>
                    <div class="row" style="border: 2px solid black;">
                        <table class="table cl_invoice"
                               style="position:relative; left:10px; margin-bottom:0px !important; margin-top:10px ;">
                            <tbody>
                                <tr style="max-height:15px; font-size:12px !important;">
                                    <td style="border-top:0px !important;padding:0px !important;"><strong>Señor
                                        (es):</strong></td>
                                    <td style="border-top:0px !important;padding:0px !important;min-width:400px;max-width:400px;"><span
                                            t-field="commercial_partner_id.name"/></td>
                                    <td style="border-top:0px !important;padding:0px !important;"><strong>
                                        Fecha:</strong></td>
                                    <td style="border-top:0px !important;padding:0px !important;"><t
                                            t-if="'date_invoice' in o and o.date_invoice"><span
                                            t-field="o.date_invoice"/></t></td>
                                </tr>
                                <tr style="max-height:15px; font-size:12px !important;">
                                    <td style="border-top:0px !important;padding:0px !important;"><strong>
                                        RUT:</strong></td>
                                    <td style="border-top:0px !important;padding:0px !important;min-width:400px;max-width:400px;"><span
                                            t-field="commercial_partner_id.document_number"/></td>
                                    <td style="border-top:0px !important;padding:0px !important;"><strong>
                                        Comuna:</strong></td>
                                    <td style="border-top:0px !important;padding:0px !important;"><span
                                            t-field="partner_id.city_id.name"/><span t-field="partner_id.street2"/></td>
                                </tr>
                                <tr style="max-height:15px; font-size:12px !important;">
                                    <td style="border-top:0px !important;padding:0px !important;"><strong>
                                        Domicilio:</strong></td>
                                    <td style="border-top:0px !important;padding:0px !important;min-width:400px;max-width:400px;"><span
                                            t-field="partner_id.street"/></td>
                                    <td style="border-top:0px !important;padding:0px !important;"><strong>
                                        Ciudad:</strong></td>
                                    <td style="border-top:0px !important;padding:0px !important;"><span
                                            t-field="partner_id.city"/></td>
                                </tr>
                                <tr style="max-height:15px; font-size:12px !important;">
                                    <td style="border-top:0px !important;padding:0px !important;"><strong>
                                        Giro:</strong></td>
                                    <td style="border-top:0px !important;padding:0px !important;min-width:400px;max-width:400px;">
                                        <t t-if="o.acteco_id">
                                            <span t-field="o.acteco_id.name"
                                                  style="color:black; text-align:center;"/><br/>
                                        </t>
                                        <t t-else="">
                                            <span t-field="o.activity_description.name"
                                                  style="color:black; text-align:center;"/><br/>
                                        </t>
                                    </td>
                                    <td style="border-top:0px !important;padding:0px !important;"><strong>Condición de
                                        Pago:</strong></td>
                                    <td style="border-top:0px !important;padding:0px !important;"><span
                                            t-if="'payment_term_id' in o and o.payment_term_id"
                                            t-field="o.payment_term_id.name"/></td>
                                </tr>
                                <tr style="max-height:15px; font-size:12px !important;">
                                    <td style="border-top:0px !important;padding:0px !important;"><strong>
                                        Contacto:</strong></td>
                                    <td style="border-top:0px !important;padding:0px !important;min-width:400px;max-width:400px;"><t
                                            t-if="'contact_id' in o and o.contact_id"><span
                                            t-field="o.contact_id.name"/></t></td>
                                    <td style="border-top:0px !important;padding:0px !important;"><strong>
                                        Vencimiento:</strong></td>
                                    <td style="border-top:0px !important;padding:0px !important;"><span
                                            t-field="o.date_due"/></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="clearfix" style="position:relative;padding-top:5px;">
                        <t t-if="o.referencias">
                            <span style="font-size:8px;"> Documento de Referencia</span>
                            <div class="row" style="border: 2px solid black; min-height:20px;" name="reference">
                                <table class="table table-condensed">
                                    <thead style="max-height:15px; font-size:8px !important;">
                                        <th>
                                            <strong>Folio:</strong>
                                        </th>
                                        <th>
                                            <strong>Referencia:</strong>
                                        </th>
                                        <th>
                                            <strong>Motivo/observación:</strong>
                                        </th>
                                        <th>
                                            <strong>Fecha del documento</strong>
                                        </th>
                                    </thead>
                                    <tbody t-if="'referencias' in o and o.referencias">
                                        <t t-foreach="o.referencias" t-as="l">
                                            <tr style="max-height:8px; font-size:10px !important;">
                                                <td style="border-top:0px !important;padding:0px !important;">
                                                    <span t-if="l.origen" t-field="l.origen"/>
                                                </td>
                                                <td style="border-top:0px !important;padding:0px !important;">
                                                    <span t-if="l.sii_referencia_TpoDocRef"
                                                          t-field="l.sii_referencia_TpoDocRef.name"/>
                                                </td>
                                                <td name="reference"
                                                    style="border-top:0px !important;padding:0px !important;">
                                                    <t t-if="l.sii_referencia_CodRef"><span
                                                            t-esc="l.sii_referencia_CodRef[0]"/> <span
                                                            t-field="l.sii_referencia_CodRef"/>: </t><span
                                                        t-if="l.motivo" t-field="l.motivo"/>
                                                </td>
                                                <td style="border-top:0px !important;padding:0px !important;">
                                                    <span t-if="l.fecha_documento" t-field="l.fecha_documento"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>
                        <!-- Is there a discount on at least one line? -->
                        <t t-set="display_discount" t-value="any([l.discount for l in o.invoice_line_ids])"/>
                        <t t-set="price_included" t-value="o.is_price_included()"/>
                        <div t-if="price_included">Valores IVA incluído</div>
                        <table style="position:relative" class="table table-condensed">
                            <thead>
                                <tr style="max-height:8px; line-height:12px; font-size:12px !important; padding:0px;">
                                    <th>Cantidad</th>
                                    <th>Artículo</th>
                                    <th>Descripción</th>
                                    <th class="text-teft">Precio Unitario</th>
                                    <th t-if="display_discount" class="text-left"
                                        groups="sale.group_discount_per_so_line">Desc.(%)</th>
                                    <th class="text-left">Precio</th>
                                </tr>
                            </thead>
                            <tbody class="invoice_tbody">

                                <t t-foreach="o.invoice_line_ids" t-as="l">
                                    <tr style="max-height:8px;line-height:10px !important; font-size:12px !important;">
                                        <td style="max-height:8px;line-height:10px !important;">
                                            <span t-field="l.quantity"/>
                                            <span t-field="l.uom_id" groups="product.group_uom"/>
                                        </td>
                                        <td style="max-height:8px;line-height:10px !important;"><span
                                                t-field="l.product_id.default_code"/></td>
                                        <td style="max-height:8px;line-height:10px !important;"><span
                                                t-field="l.name"/></td>
                                        <td class="text-left" style="max-height:8px;line-height:10px !important;">
                                            <span t-field="l.price_unit"
                                                  t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                        </td>
                                        <td t-if="display_discount" class="text-right"
                                            groups="sale.group_discount_per_so_line"
                                            style="max-height:8px;line-height:10px !important;">
                                            <span t-field="l.discount"/>
                                        </td>
                                        <td class="text-left" style="max-height:8px;line-height:10px !important;">
                                            <!-- <span t-field="l.price_total" t-field-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/> -->
                                            <span t-field="l.price_unit"
                                                  t-field-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                        </td>

                                    </tr>

                                    <t t-set="count" t-value="count+1"/>
                                </t>
                            </tbody>
                        </table>
                    </div>
                    <div class="clearfix" style="position:relative">
                        <p t-if="o.comment">
                            <strong>Comment:</strong>
                            <span t-field="o.comment"/>
                        </p>
                        <div class="row">
                            <div class="col-xs-5">
                                <div class="col-xs-12">
                                    <span t-field="o.sii_barcode_img"
                                          t-field-options="{&quot;widget&quot;: &quot;image&quot;}"/>
                                </div>
                                <div class="col-xs-12">
                                    <p style="text-align:center;color:red; font-size:8px;">
                                        Timbre Electrónico SII
                                        <br/>
                                        Resolución <t t-esc='o.company_id.dte_resolution_number'/> de <t
                                            t-esc='o.company_id.dte_resolution_date[:4]'/> Verifique documento en: <t
                                            t-if="not o._es_boleta()">www.sii.cl</t><t t-if="o._es_boleta()"
                                                                                       t-esc="'%s/boleta/%s' % (o.company_id.website, o.sii_document_number)"/>
                                    </p>
                                </div>
                            </div>
                            <div id="total" class="col-xs-4 pull-right">
                                <table class="table table-condensed">
                                    <t t-if="o.global_descuentos_recargos">
                                        <tr t-foreach="o.global_descuentos_recargos" t-as="gdr" class="border-black"
                                            style="max-height:11px; font-size:12px !important;">
                                            <td><strong>Descuento o Recargo Global</strong></td>
                                            <td class="text-right">
                                                <span t-esc="gdr.valor if gdr.gdr_type=='amount' else gdr.amount_untaxed_global_dr"
                                                      t-esc-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                            </td>
                                        </tr>
                                    </t>
                                    <tr style="max-height:11px; font-size:12px !important;" name="subtotal"
                                        t-if="not price_included">
                                        <td><strong>Subtotal</strong></td>
                                        <td class="text-right">
                                            <span t-field="o.amount_untaxed"
                                                  t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                        </td>
                                    </tr>
                                    <tr name="discount" t-if="display_discount" class="border-black"
                                        style="max-height:11px; font-size:12px !important;">
                                        <td><strong>Descuento</strong></td>
                                        <td class="text-right">
                                            <span t-esc="o.getTotalDiscount()"
                                                  t-esc-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                        </td>
                                    </tr>
                                    <t t-foreach="o.tax_line_ids" t-as="t">
                                        <tr t-if="not o._es_boleta() or t.tax_id.sii_detailed or t.tax_id.amount == 0"
                                            style="max-height:11px; font-size:12px !important;">
                                            <td><span t-field="t.tax_id.description"/></td>
                                            <td class="text-right">
                                                <span t-esc="t.amount if t.amount > 0 else t.base"
                                                      t-esc-options='{"widget": "monetary", "display_currency": "o.currency_id"}'/>
                                            </td>
                                        </tr>
                                    </t>
                                    <tr class="border-black" style="max-height:12px; font-size:12px !important;">
                                        <td><strong>Total</strong></td>
                                        <td class="text-right">
                                            <span t-field="o.amount_total"
                                                  t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                        <t t-if="cedible">
                            <div class="row">
                                <div class="col-xs-12"
                                     style="border: 1px solid black;height:20px;font-size:15px !important;">
                                    <div class="col-xs-4">
                                        <strong>Nombre:</strong>
                                    </div>
                                </div>
                                <div class="col-xs-12"
                                     style="border: 1px solid black;height:20px;font-size:15px !important;">
                                    <div class="col-xs-7">
                                        <strong>R.U.T.:</strong>
                                    </div>
                                    <div class="col-xs-5">
                                        <strong>FECHA:</strong>
                                    </div>
                                </div>
                                <div class="col-xs-12"
                                     style="border: 1px solid black;height:20px; font-size:15px !important;">
                                    <div class="col-xs-7">
                                        <strong>RECINTO:</strong>
                                    </div>
                                    <div class="col-xs-5">
                                        <strong>FIRMA:</strong>
                                    </div>
                                </div>
                                <div class="col-xs-12" style="border: 1px solid black;">
                                    <p style="position:relative; left:15px; font-size:8px">
                                        "El acuse de recibo que se declara en este acto, de acuerdo a lo dispuesto en la
                                        letra b) del Artículo 4°, y la letra c) del Artículo 5° de la Ley 19.983,
                                        acredita
                                        que la entrega de mercaderías o servicio(s) prestado(s) ha(n) sido recibido(s)"
                                    </p>
                                </div>
                                <div class="col-xs-12" style="border: 1px solid black;">
                                    <p style="position:relative; left:15px; font-size:14px">
                                        OUTSIDE SPORTS SPA, RUT 76.742.844-8, C/Vista Banco Estado: 05770122971,
                                        administracion@outsidesports.cl
                                    </p>
                                </div>
                            </div>
                            <div class="row">
                                <p class="pull-right">CEDIBLE</p>
                            </div>
                        </t>
                        <div class="row">

                        </div>
                    </div>

                </div>
                <div class="footer">
                    <div class="row">
                        <div class="col-xs-12">
                            <p class="text-center" style="font-size:12px!important;">
                                <span t-field="company.name"/> -
                                <strong>RUT:</strong> <span t-field="company.document_number"/> -
                                <strong>Banco:</strong> <span t-field="o.res_bank_account"/> -
                                <strong>Cuenta Bancaria:</strong> <span t-field="o.res_account_name"/></p>
                        </div>
                    </div>
                </div>
            </xpath>

        </template>

    </data>
</odoo>