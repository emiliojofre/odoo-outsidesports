<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="nlh_stock_picking" inherit_id="l10n_cl_stock_picking.dte_stock_picking">
        <xpath expr="//t[@t-foreach='docs']" position="replace">
            <style>
                .table{
                margin-bottom:0px !important;
                }
            </style>

            <t t-foreach="docs" t-as="o">
                <t t-lang="'es_CL">
                    <!-- Multicompany -->
                    <t t-if="not o and doc">
                        <t t-set="o" t-value="doc"/>
                    </t>
                    <t t-set="partner_id" t-value="o.partner_id or o.company_id.partner_id"/>
                    <t t-if="not o and doc">
                        <t t-set="o" t-value="doc"/>
                    </t>
                    <t t-if="o and 'company_id' in o">
                        <t t-set="company" t-value="o.company_id.sudo()"/>
                    </t>
                    <t t-if="not o or not 'company_id' in o">
                        <t t-set="company" t-value="res_company"/>
                    </t>
                    <t t-if="'journal_document_class_id' in o and o.journal_document_class_id">
                        <t t-set="document_class_id" t-value="o.journal_document_class_id.sii_document_class_id"/>
                    </t>
                    <t t-set="commercial_partner_id" t-value="o.partner_id.commercial_partner_id"/>
                    <t t-set="logo" t-value="company.logo"/>

                    <div class="header">
                        <div class="row">
                            <div class="col-xs-6">
                                <p style="text-align:left;text-transform:uppercase;font-weight:900;font-size:20px;color:black;">
                                    <span t-field="o.company_id.partner_id.ref"/>
                                </p>
                            </div>
                        </div>


                        <div class="row">

                            <table height="10" border="0">
                                <tr>
                                    <th colspan="2" scope="col">
                                        <div class="col-xs-12"
                                             style="text-align:center; margin-bottom:-150px;  padding-top:-20px;">
                                            <h3 style="text-align:lef;text-transform:uppercase;font-weight:900;font-size:28px;color:black;">
                                                <span t-field="company.name"/>
                                            </h3>

                                            <h4 style="text-align:lef;text-transform:uppercase;font-weight:900;font-size:12px;color:black;">
                                                <span t-field="company.activity_description.name"
                                                      style="color:black; text-align:center;"/><br/>
                                            </h4>
                                        </div>
                                    </th>
                                    <th rowspan="2" scope="col">
                                        <div class="col-xs-5" style="position:relative; left:45px; top:20;">
                                            <div style="position:relative; left:5px; border:3px solid red; text-align:center;font-size:20px;padding-bottom:0px !important; height:145px; width:360px;">
                                                <h6 style="color:red;font-size:20px;padding-bottom:10px; padding-top:5px; font-family:Arial;">
                                                    R.U.T.: <span t-field="company.document_number"/>
                                                </h6>
                                                <h6 name="document_class_id" t-if="o.document_class_id"
                                                    style="line-height:23px;font-size:20px;color:red;text-align:center;text-transform:uppercase;padding-bottom:10px;font-family:Arial;">
                                                    <span t-field="o.document_class_id.name"/>
                                                </h6>
                                                <h6 t-if="'sii_document_number' in o and o.sii_document_number"
                                                    style="color: red;text-align: center;font-size:20px;padding-bottom:5px;font-family:Arial;">
                                                    N° <span t-esc="o.sii_document_number"/>
                                                </h6>
                                                <br/>
                                            </div>
                                            <div class="row"
                                                 style="text-align: center; margin-top:0px !important; padding-top:0px!important;">
                                                <h7 style="position:relative;left:120px;color:red;text-align:center;font-size:12px;text-transform:uppercase;">
                                                    SII - <span t-field="o.company_id.sii_regional_office_id.name"/>
                                                </h7>
                                            </div>
                                        </div>
                                    </th>
                                </tr>

                                <tr>
                                    <th height="10" scope="col">
                                        <p style="position:relative; top:-25px;text-align:left;font-size:1px;color:black; padding-top:0px ; margin-top:-5px; top:-20px; border-bottom:-15px;">
                                            <img t-if="logo" t-att-src="'data:image/png;base64,%s' % to_text(logo)"
                                                 style="max-height: 250px; margin-top:-25px; border-bottom:-15px;"/><br/>
                                        </p>
                                    </th>
                                    <th height="10" scope="col">
                                        <p style="position:relative; top:-55px;text-align:left;font-size:12px;color:black; margin-top:-10px; border-top:-10px; border-bottom:-15px; text-transform:uppercase;">
                                            <span t-field="company.street"/><br/>
                                            <span t-field="company.city_id.name"/>, <span t-field="company.city"/><br/>
                                            <span><span t-field="company.phone"/></span><br/>
                                            <span><span t-field="company.email"/></span><br/>
                                            <span t-field="company.website"/>
                                        </p>
                                    </th>
                                </tr>
                            </table>

                        </div>

                    </div>
                    <div class="article">
                        <div class="page" style="position:relative; top:100px;">
                            <div class="oe_structure"/>
                            <div class="row" style="border: 2px solid black;">
                                <table class="table cl_invoice"
                                       style="position:relative; left:10px; margin-bottom:0px !important; margin-top:10px ;">
                                    <tbody>
                                        <tr style="max-height:15px; font-size:12px !important;">
                                            <td style="border-top:0px !important;padding:0px !important;"><strong>Señor
                                                (es):</strong></td>
                                            <td style="border-top:0px !important;padding:0px !important;min-width:400px;max-width:400px;"><span
                                                    t-field="partner_id.commercial_partner_id.name"/></td>
                                            <td style="border-top:0px !important;padding:0px !important;"><strong>
                                                Fecha:</strong></td>
                                            <td style="border-top:0px !important;padding:0px !important;">
                                                <t t-if="'scheduled_date' in o and o.scheduled_date">
                                                    <span t-field="o.scheduled_date"/>
                                                </t>
                                            </td>
                                        </tr>
                                        <tr style="max-height:15px; font-size:12px !important;">
                                            <td style="border-top:0px !important;padding:0px !important;"><strong>
                                                RUT:</strong></td>
                                            <td style="border-top:0px !important;padding:0px !important;min-width:400px;max-width:400px;"><span
                                                    t-field="partner_id.commercial_partner_id.document_number"/></td>
                                            <td style="border-top:0px !important;padding:0px !important;"><strong>
                                                Comuna:</strong></td>
                                            <td style="border-top:0px !important;padding:0px !important;"><span
                                                    t-field="partner_id.city_id.name"/><span
                                                    t-field="partner_id.street2"/></td>
                                        </tr>
                                        <tr style="max-height:15px; font-size:12px !important;">
                                            <td style="border-top:0px !important;padding:0px !important;"><strong>
                                                Domicilio:</strong></td>
                                            <td style="border-top:0px !important;padding:0px !important;min-width:400px;max-width:400px;"><span
                                                    t-field="partner_id.street"/></td>
                                            <td style="border-top:0px !important;padding:0px !important;"><strong>
                                                Ciudad:</strong></td>
                                            <td style="border-top:0px !important;padding:0px !important;"><span
                                                    t-field="partner_id.city"/></td>
                                        </tr>
                                        <tr style="max-height:15px; font-size:12px !important;">
                                            <td style="border-top:0px !important;padding:0px !important;"><strong>
                                                Giro:</strong></td>
                                            <td style="border-top:0px !important;padding:0px !important;min-width:400px;max-width:400px;"><span
                                                    t-field="o.activity_description.name"/>
                                            </td>
                                            <td style="border-top:0px !important;padding:0px !important;"><strong>
                                                Condición de Pago:</strong></td>
                                            <td style="border-top:0px !important;padding:0px !important;"><span
                                                    t-if="'payment_term_id' in o and o.payment_term_id"
                                                    t-field="o.payment_term_id.name"/></td>
                                        </tr>
                                        <tr style="max-height:15px; font-size:12px !important;">
                                            <td style="border-top:0px !important;padding:0px !important;"><strong>
                                                Contacto:</strong></td>
                                            <td style="border-top:0px !important;padding:0px !important;min-width:400px;max-width:400px;"><t
                                                    t-if="'contact_id' in o and o.contact_id"><span
                                                    t-field="o.contact_id.name"/></t></td>
                                            <td style="border-top:0px !important;padding:0px !important;"><strong>
                                                Vencimiento:</strong></td>
                                            <td style="border-top:0px !important;padding:0px !important;"><span
                                                    t-field="o.scheduled_date"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                            <div style="position:relative;padding-top:5px;" class="row">
                                <div t-if="'reference' in o and o.reference">
                                    <span style="font-size:8px;">Documento de Referencia</span>
                                    <div class="row" style="border: 2px solid black; min-height:20px;"
                                         name="reference">
                                        <table style="position:relative;" class="table table-condensed">
                                            <thead style="max-height:15px; font-size:8px !important;">
                                                <th>
                                                    <strong>Folio:</strong>
                                                </th>
                                                <th>
                                                    <strong>Reference:</strong>
                                                </th>
                                                <th>
                                                    <strong>Fecha:</strong>
                                                </th>
                                            </thead>
                                            <tbody>
                                                <t t-foreach="o.reference" t-as="l">
                                                    <tr style="max-height:8px; font-size:10px !important;">
                                                        <td style="document_class_idborder-top:0px !important;padding:0px !important;">
                                                            <span t-if="l.origen" t-field="l.origen"/>
                                                        </td>
                                                        <td style="border-top:0px !important;padding:0px !important;">
                                                            <span t-if="l.sii_referencia_TpoDocRef"
                                                                  t-field="l.sii_referencia_TpoDocRef.name"/>
                                                        </td>
                                                        <td style="border-top:0px !important;padding:0px !important;">
                                                            <span t-if="l.date" t-field="l.date"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <!-- Is there a discount on at least one line? -->
                                <table style="position:relative" class="table table-condensed">
                                    <thead>
                                        <tr style="max-height:8px; line-height:12px; font-size:12px !important; padding:0px;">
                                            <th>Cantidad</th>
                                            <th>Descripción</th>
                                            <th class="text-right">Precio Unitario</th>
                                            <th t-if="display_discount" class="text-right"
                                                groups="sale.group_discount_per_so_line">Desc.(%)
                                            </th>
                                            <th class="text-right">Precio</th>
                                        </tr>
                                    </thead>
                                    <tbody class="invoice_tbody">
                                        <tr t-foreach="o.move_lines.sorted(key=lambda m: m.product_id.id)" t-as="l"
                                            style="max-height:8px;line-height:10px !important; font-size:12px !important;">
                                            <td style="max-height:8px;line-height:10px !important;">
                                                <span t-field="l.quantity_done"/>
                                                <span t-field="l.product_uom" groups="product.group_uom"/>
                                            </td>
                                            <td style="max-height:8px;line-height:10px !important;">
                                                <span t-field="l.name"/>
                                            </td>
                                            <td style="max-height:8px;line-height:10px !important;" class="text-right">
                                                <span t-field="l.precio_unitario"
                                                      t-field-options='{"widget": "monetary", "display_currency": "o.currency_id"}'/>
                                            </td>
                                            <td style="max-height:8px;line-height:10px !important;"
                                                t-if="display_discount" class="text-right"
                                                groups="sale.group_discount_per_so_line">
                                                <span t-field="l.discount"/>
                                            </td>
                                            <td style="max-height:8px;line-height:10px !important;" class="text-right"
                                                t-if="'subtotal' in l">
                                                <span t-field="l.subtotal"
                                                      t-field-options='{"widget": "monetary", "display_currency": "o.currency_id"}'/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <!-- Nombre, Rut, Recinto-->
                            <div class="clearfix" style="position:relative">
                                <div class="row" style="border:1px solid black; height:30px;">

                                    <table class="table table-condensed" style="height:30px;">
                                        <thead>
                                            <tr style="max-height:10px; font-size:9px !important;">
                                                <th>Nombre</th>
                                                <th>RUT</th>
                                                <th name="td_sched_date_h">Patente</th>
                                                <th>Tipo Operación</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr style="max-height:9px; font-size:8px !important;">
                                                <td>
                                                    <span t-field="o.chofer.name"/>
                                                </td>
                                                <td>
                                                    <span t-field="o.chofer.document_number"/>
                                                </td>
                                                <td name="td_sched_date">
                                                    <span t-field="o.patente"/>
                                                </td>
                                                <td>ue
                                                    <span t-field="o.move_reason"/>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                    <table t-if="partner_id.type in ['delivery', 'other']" class="table table-condensed"
                                           style="height:30px;">
                                        <thead>
                                            <tr style="max-height:10px; font-size:9px !important;">
                                                <th>Dirección de Envío</th>
                                                <th>Ciudad</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr style="max-height:9px; font-size:8px !important;">
                                                <td>
                                                    <span t-field="partner_id.street"/>
                                                </td>
                                                <td>
                                                    <span t-field="partner_id.city"/>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <br/>
                            <!--     Timbre electronico-->
                            <div class="clearfix" style="position:relative">
                                <p t-if="o.note">
                                    <strong>Notas:</strong>
                                    <span t-field="o.note"/>
                                </p>
                                <div class="row">
                                    <div class="col-xs-5">
                                        <div class="col-xs-12">
                                            <span t-field="o.sii_barcode_img"
                                                  t-field-options="{&quot;widget&quot;: &quot;image&quot;}"/>
                                        </div>
                                        <div class="col-xs-12">
                                            <p style="text-align:center;color:red; font-size:8px;">
                                                Timbre Electrónico SII
                                                <br/>
                                                Resolución
                                                <t t-esc='o.company_id.dte_resolution_number'/>
                                                de
                                                <t t-esc='o.company_id.dte_resolution_date[:4]'/>
                                                Verifique documento: www.sii.cl
                                            </p>
                                        </div>
                                    </div>
                                    <div class="col-xs-4 pull-right">
                                        <table class="table table-condensed">
                                            <tr class="border-black" t-if="'global_discount' in o">
                                                <td>
                                                    <strong>Descuento</strong>
                                                </td>
                                                <td class="text-right">
                                                    <span t-field="o.global_discount"
                                                          t-field-options='{"widget": "monetary", "display_currency": "o.currency_id"}'/>
                                                </td>
                                            </tr>
                                            <tr t-if="'subtotal' in o">
                                                <td>
                                                    <strong>Subtotal</strong>
                                                </td>
                                                <td class="text-right">
                                                    <span t-field="o.amount_untaxed"
                                                          t-field-options='{"widget": "monetary", "display_currency": "o.currency_id"}'/>
                                                </td>
                                            </tr>
                                            <t t-if="'tax_line_ids' in o">
                                                <tr t-foreach="o.tax_line_ids" t-as="t">
                                                    <td>
                                                        <span t-field="t.name"/>
                                                    </td>
                                                    <td class="text-right">
                                                        <span t-field="t.amount"
                                                              t-field-options='{"widget": "monetary", "display_currency": "o.currency_id"}'/>
                                                    </td>
                                                </tr>
                                            </t>
                                            <tr class="border-black" t-if="'amount_total' in o">
                                                <td>
                                                    <strong>Total</strong>
                                                </td>
                                                <td class="text-right">
                                                    <span t-field="o.amount_total"
                                                          t-field-options='{"widget": "monetary", "display_currency": "o.currency_id"}'/>
                                                </td>
                                            </tr>
                                        </table>
                                    </div>
                                </div>
                            </div>
                            <!--Nombre rut recinto fecha firma-->
                            <div class="row">
                                <div class="col-xs-12"
                                     style="border: 1px solid black;height:20px;font-size:15px !important;">
                                    <div class="col-xs-4">
                                        <strong>Nombre:</strong>
                                    </div>
                                </div>
                                <div class="col-xs-12"
                                     style="border: 1px solid black;height:20px;font-size:15px !important;">
                                    <div class="col-xs-7">
                                        <strong>R.U.T.:</strong>
                                    </div>
                                    <div class="col-xs-5">
                                        <strong>FECHA:</strong>
                                    </div>
                                </div>
                                <div class="col-xs-12"
                                     style="border: 1px solid black;height:20px; font-size:15px !important;">
                                    <div class="col-xs-7">
                                        <strong>RECINTO:</strong>
                                    </div>
                                    <div class="col-xs-5">
                                        <strong>FIRMA:</strong>
                                    </div>
                                </div>
                                <div class="col-xs-12" style="border: 1px solid black;">
                                    <p style="position:relative; left:15px; font-size:8px">
                                        "El acuse de recibo que se declara en este acto, de acuerdo a lo dispuesto
                                        en la
                                        letra b) del Artículo 4°, y la letra c) del Artículo 5° de la Ley 19.983,
                                        acredita que la entrega de mercaderías o servicio(s) prestado(s) ha(n) sido
                                        recibido(s)"
                                    </p>
                                </div>
                            </div>
                            <div class="row">
                                <h6 class="pull-right" t-if="cedible">CEDIBLE CON SU FACTURA</h6>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </xpath>

    </template>

</odoo>
