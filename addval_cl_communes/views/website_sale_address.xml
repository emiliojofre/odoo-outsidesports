<odoo>
    <template id="inherit_address" inherit_id="website_sale.address" name="Add city in address">
        <xpath expr="//div[contains(@t-attf-class, 'mb-3')][contains(@t-attf-class, 'div_street2')]" position="attributes">
            <attribute name="t-attf-style">display: none;</attribute>
        </xpath>

        <!-- <xpath expr="//div[contains(@t-attf-class, 'mb-3')][contains(@t-attf-class, 'div_zip')]" position="attributes">
            <attribute name="t-attf-style">display: none;</attribute>
        </xpath> -->

        <!-- <xpath expr="//div[contains(@t-attf-class, 'mb-3')][contains(@t-attf-class, 'div_state')]" position="attributes">
            <attribute name="t-attf-style">display: none;</attribute>
        </xpath> -->

        <xpath expr="//div[contains(@t-attf-class, 'mb-3')][contains(@t-attf-class, 'div_state')]" position="replace">
        </xpath>

        <!-- <xpath expr="//t[@t-set='zip_city']" position="replace">
            <t t-set='zip_city' t-value='country and [x for x in country.get_address_fields() if x in ["zip", "city"]] or ["city", "zip"]'/>
        </xpath> -->

        <xpath expr="//div[contains(@t-attf-class, 'mb-3')][contains(@t-attf-class, 'div_street')]" position="after">
            <div t-attf-class="mb-3 #{error.get('street2') and 'o_has_error' or ''} col-lg-12 div_street2">
                <label class="col-form-label label-optional" for="street2">Calle 2</label>
                <input type="text" name="street2" t-attf-class="form-control #{error.get('street2') and 'is-invalid' or ''}" t-att-value="'street2' in checkout and checkout['street2']" />
            </div>
        </xpath>
        <!-- <xpath expr="//div[contains(@t-attf-class, 'mb-3')][contains(@t-attf-class, 'div_city')]" position="before">
            <div t-attf-class="mb-3 #{error.get('zip') and 'o_has_error' or ''} col-md-4 div_zip">
                <label class="col-form-label label-optional" for="zip">Código Postal</label>
                <input type="text" name="zip" t-attf-class="form-control #{error.get('zip') and 'is-invalid' or ''}" t-att-value="'zip' in checkout and checkout['zip']" />
            </div>
        </xpath> -->
        <xpath expr="//div[contains(@t-attf-class, 'mb-3')][contains(@t-attf-class, 'div_country')]" position="before">
            <div t-attf-class="mb-3 #{error.get('state_id') and 'o_has_error' or ''} col-lg-6 div_state">
                <label class="col-form-label" for="state_id">Región</label>
                <select name="state_id" t-attf-class="form-select #{error.get('state_id') and 'is-invalid' or ''}" data-init="1">
                    <option value="">Región ...</option>
                    <t t-foreach="country_states" t-as="s">
                        <t t-if="s.id in country.state_ids.ids">
                            <option t-att-value="s.id" t-att-selected="s.id == ('state_id' in checkout and country and checkout['state_id'] != '' and int(checkout['state_id']))">
                                <t t-esc="s.name" />
                            </option>
                        </t>
                    </t>
                </select>
            </div>
        </xpath>

        <xpath expr="//div[contains(@t-attf-class, 'mb-3')][contains(@t-attf-class, 'div_city')]" position="replace">
            <div t-attf-class="mb-3 #{error.get('city') and 'o_has_error' or ''} col-md-8 div_city">
                <label class="col-form-label" for="city">Ciudad</label>
                <select name="city" class="form-select" t-attf-class="form-control #{error.get('city') and 'is-invalid' or ''}" t-att-mode="mode[1]">
                    <option value="">Ciudad...</option>
                    <t t-foreach="cities" t-as="city">
                        <option t-att-value="city.id" t-att-selected="('city' in checkout and checkout['city'] == city.id) or -1">
                            <t t-esc="city.name" />
                        </option>
                    </t>
                </select>
            </div>
            <script>
                document.addEventListener('DOMContentLoaded', function() {
                    // Handler para el cambio en el selector de regiones
                    document.querySelector('select[name="state_id"]').addEventListener('change', function() {
                        var stateId = this.value; // Obtener el ID del estado seleccionado
                        var citySelect = document.querySelector('select[name="city"]'); // Selector del campo de ciudades
                        console.log('HOLA');

                        // Limpia las opciones actuales del selector de ciudades
                        citySelect.innerHTML = '';

                        // Agrega una opción predeterminada
                        var defaultOption = document.createElement('option');
                        defaultOption.value = '';
                        defaultOption.text = 'Ciudad...';
                        citySelect.appendChild(defaultOption);

                        // Itera sobre las ciudades disponibles
                        cities.forEach(function(city) {
                            // Si la ciudad pertenece al estado seleccionado, agrégala al selector de ciudades
                            if (city.state_id.id === stateId) {
                                var option = document.createElement('option');
                                option.value = city.id;
                                option.text = city.name;
                                citySelect.appendChild(option);
                            }
                        });
                    });
                });
            </script>
        </xpath>

    </template>

    <!-- 
        Pais      / Country   (country_id)
        Provincia / State     (state_id)
        Ciudad    / City      (city_id)
        ZIP                   (zipcode)
        Calle     / Street    (street)
         -->
</odoo>