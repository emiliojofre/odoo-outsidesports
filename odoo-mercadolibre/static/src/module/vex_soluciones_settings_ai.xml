<?xml version="1.0" encoding="UTF-8"?>
<template xml:space="preserve">
    <t t-name="vex_sync_mercado_libre.settings_ai" owl="1">
        <div class="container mt-4">
            <div class="row">
              <div class="col-md-6">
                <h5>Automatización ML a Odoo</h5>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="processAllNotifications" />
                  <label class="form-check-label" for="processAllNotifications">Process all notifications</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="importOrders" />
                  <label class="form-check-label" for="importOrders">Importar pedidos</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="importShipments" />
                  <label class="form-check-label" for="importShipments">Importar envíos</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="importClients" />
                  <label class="form-check-label" for="importClients">Importar clientes</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="importQuestions" />
                  <label class="form-check-label" for="importQuestions">Importar preguntas</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="searchSKU" />
                  <label class="form-check-label" for="searchSKU">Search SKU</label>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="importNonexistentProducts" />
                  <label class="form-check-label" for="importNonexistentProducts">Importar productos inexistentes</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="updateAddVariants" />
                  <label class="form-check-label" for="updateAddVariants">Actualiza/agrega variantes</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="updateProducts" />
                  <label class="form-check-label" for="updateProducts">Actualizar productos</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="importNewProducts" />
                  <label class="form-check-label" for="importNewProducts">Importar nuevos productos</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="cronGetProducts" />
                  <label class="form-check-label" for="cronGetProducts">Cron Get Products and take Stock from ML</label>
                </div>
                <div class="form-group">
                  <label for="actionOnOrderReceive">Acción al recibir un pedido</label>
                  <select class="form-control" id="actionOnOrderReceive">
                    <option>Option 1</option>
                    <option>Option 2</option>
                    <option>Option 3</option>
                  </select>
                </div>
              </div>
            </div>
            <div class="row mt-4">
              <div class="col-md-6">
                <h5>Automatización Odoo a ML</h5>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="updateProductsOdoo" />
                  <label class="form-check-label" for="updateProductsOdoo">Actualizar productos</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="includeNewProducts" />
                  <label class="form-check-label" for="includeNewProducts">Incluir nuevos productos</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="publishStock" />
                  <label class="form-check-label" for="publishStock">Publicar Stock</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="publishPrice" />
                  <label class="form-check-label" for="publishPrice">Publicar Precio</label>
                </div>
              </div>
              <div class="col-md-6">
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="postSKU" />
                  <label class="form-check-label" for="postSKU">Post SKU</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="productTemplateOverrideVariant" />
                  <label class="form-check-label" for="productTemplateOverrideVariant">Product template override Variant</label>
                </div>
                <div class="form-group">
                  <label for="overrideMethod">Método para Sobrescribir</label>
                  <select class="form-control" id="overrideMethod">
                    <option>Predeterminado, sobrescribe descripción</option>
                    <option>Option 2</option>
                    <option>Option 3</option>
                  </select>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="createProductAttributes" />
                  <label class="form-check-label" for="createProductAttributes">Create Product Attributes</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="checkbox" id="doNotUseFirstImage" />
                  <label class="form-check-label" for="doNotUseFirstImage">Do not use first image</label>
                </div>
              </div>
            </div>
          </div>
    </t>
</template>