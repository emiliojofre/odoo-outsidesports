<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="odoo-mercadolibre.product_ads" owl="1">
        <script src="https://cdn.sheetjs.com/xlsx-0.20.3/package/dist/xlsx.full.min.js"></script>
        <t t-if="state.currentView == 'table'">
        <!-- GRAPH -->
            <div class="container column d-flex" style="margin: 0px;max-width: -webkit-fill-available;">
                <div class="col-6" style="justify-self: flex-start; display: flex; margin:3px">
                    <button class="btn" t-att-class="{'btn-primary': state.activeMetricCamp == 'clicks', 'btn-outline-primary': state.activeMetricCamp != 'clicks'}" style="margin-inline: 10px;" t-on-click="() => changeMetricCamp('clicks')">Clics</button>
                    <button class="btn" t-att-class="{'btn-primary': state.activeMetricCamp == 'prints', 'btn-outline-primary': state.activeMetricCamp != 'prints'}" style="margin-inline: 10px;" t-on-click="() => changeMetricCamp('prints')">Prints</button>
                    <button class="btn" t-att-class="{'btn-primary': state.activeMetricCamp == 'total_amount', 'btn-outline-primary': state.activeMetricCamp != 'total_amount'}" style="margin-inline: 10px;" t-on-click="() => changeMetricCamp('total_amount')">Income</button>
                    <button class="btn" t-att-class="{'btn-primary': state.activeMetricCamp == 'cost', 'btn-outline-primary': state.activeMetricCamp != 'cost'}" style="margin-inline: 10px;" t-on-click="() => changeMetricCamp('cost')">Costs</button>
                    <button class="btn" t-att-class="{'btn-primary': state.activeMetricCamp == 'acos', 'btn-outline-primary': state.activeMetricCamp != 'acos'}" style="margin-inline: 10px;" t-on-click="() => changeMetricCamp('acos')">ACOS</button>
                </div>
                <div class="col-6" style="display: flex;padding: 0px;justify-content: flex-end;">
                    <select class="custom-select mx-1" t-on-change="handleFilterChangeCamp" t-model="state.filterTypeDateCamp" id="dateFilterCamp" style="width: 150px;">
                        <option value="7">Last 7 days</option>
                        <option value="15">Last 15 days</option>
                        <option value="30">Last 30 days</option>
                        <option value="60">Last 60 days</option>
                        <option value="90">Last 90 days</option>
                    </select>
                </div>
            </div>
            
            <div class="container d-flex flex-column" style="max-width: 100%;">
                <div class="row flex-grow-1">
                    <div class="grid-stack-item col-lg-12 col-md-12 col-sm-12 mb-3 h-50" gs-w="4" gs-h="3">
                        <div class="grid-stack-item-content card-body" style="min-height: 350px;">
                            <canvas t-ref="chartCampaign"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- <button class="btn btn-primary" t-on-click="test" >test</button> -->
            <div class="o_action_manager custom-whatsapp-suite" bis_skin_checked="1" style="overflow: auto !important;">
                <style>
                    .info-icon {
                        display: inline-block;
                        width: 20px;
                        height: 20px;
                        line-height: 20px;
                        text-align: center;
                        border-radius: 50%;
                        background-color:rgb(2, 7, 12);
                        color: white;
                        font-size: 14px;
                        font-weight: bold;
                        cursor: pointer;
                        margin-left: 5px;
                    }

                    .tooltip-container {
                        position: relative;
                        cursor: pointer;
                    }

                    .tooltip-custom {
                        position: absolute;
                        background-color: rgb(255, 255, 255); 
                        color: black;
                        text-align: center;
                        padding: 8px;
                        border-radius: 5px;
                        border: 1px solid black;
                        font-size: 12px;
                        width: 150px;
                        bottom: -115%;
                        left: 50%;
                        transform: translateX(-50%);
                        opacity: 0;
                        visibility: hidden;
                        transition: opacity 0.3s ease-in-out;
                    }

                    .tooltip-container:hover .tooltip-custom {
                        opacity: 1;
                        visibility: visible;
                    }

                </style>
                <div class="o_dashboard_view my-5">
                    <div class="container" style="max-width: none !important">
                        <div class="grid-stack-item-content p-3" >
                            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4">
                                <h5 class="mb-0" style="margin: 0px 10px;">Campaigns</h5>
                                <div>
                                    <input type="text" placeholder="Search by name or type..." t-on-input="ev => updateFilterCampaign(ev, 'search')" class="form-control mr-2" id="searchInput" style="width: 200px; display: inline-block;"/>
                                    <select class="custom-select mx-1" t-on-change="ev => updateFilterCampaign(ev, 'status')" id="statusFilter" style="width: 150px;">
                                        <option value="">All Status</option>
                                        <option value="active">Active</option>
                                        <option value="paused">Paused</option>
                                        <option value="deleted">Deleted</option>
                                    </select>
                                    <button class="btn btn-primary" id="export_excel" style="margin-bottom: 1%;" t-on-click="exportToExcelCampaigns">
                                        Export to Excel
                                    </button>
                                </div>
                            </div>
                            <div class="table-responsive" style="width: 100%;"> 
                                <table class="table table-hover" id="table-campaigns">
                                    <thead class="thead-light">
                                    <tr>
                                        <th scope="col" t-esc="'Campaign'" >Campaign</th>
                                        <th scope="col" t-esc="'Status'" >Status</th>
                                        <th scope="col" t-esc="'Budget'" >Budget</th>
                                        <th scope="col" t-esc="'Type Campaign'" >Type Campaign</th>
                                        <th scope="col" t-esc="'ACOS Target'" >ACOS Target</th>
                                        <th scope="col" class="tooltip-container">
                                            Advertising Sales
                                            <span class="tooltip-custom">Amount of advertising sales.</span>
                                            <span class="info-icon">?</span></th>
                                        <th scope="col" class="tooltip-container">
                                            Prints 
                                            <span class="tooltip-custom">One impression is counted each time the ad is shown.</span>
                                            <span class="info-icon">?</span></th>
                                        <th scope="col" class="tooltip-container">
                                            Clics
                                            <span class="tooltip-custom">When a user clicks on your ad, it is counted here.</span>
                                            <span class="info-icon">?</span></th>
                                        <th scope="col" class="tooltip-container">
                                            Income
                                            <span class="tooltip-custom">Sum of the value of sales obtained from your Product Ad.</span>
                                            <span class="info-icon">?</span></th>
                                        <th scope="col" class="tooltip-container">
                                            Cost
                                            <span class="tooltip-custom">The cost corresponds to the sum of the expenses during this period.</span>
                                            <span class="info-icon">?</span></th>
                                        <th scope="col" class="tooltip-container">
                                            ACOS
                                            <span class="tooltip-custom">Percentage of investment in advertising over the income obtained.</span>
                                            <span class="info-icon">?</span></th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="paginatedCampaigns" t-as="row" t-key="row.name" t-att-data-id="row.id" t-on-click="openRecord">
                                            <td t-esc="row.name"></td>
                                            <td t-esc="row.status"></td>
                                            <td t-esc="row.budget"></td>
                                            <td t-esc="row.strategy"></td>
                                            <td t-esc="row.acos_target">%</td>
                                            <td t-esc="row.advertising_items_quantity"></td>
                                            <td t-esc="row.prints"></td>
                                            <td t-esc="row.clicks"></td>
                                            <td t-esc="row.total_amount"></td>
                                            <td t-esc="row.cost"></td>
                                            <td t-esc="row.acos">%</td>
                                        </tr>
                                    </tbody>
                                </table>
                                <div class="pagination-controls">
                                    <button class="btn btn-primary" id="prevPageCampaigns" t-on-click="prevPageCampaigns" t-att-disabled="state.currentPage_campaigns === 1">⏮ Previous </button>
                                    <span id="pageNumberCampaigns" style="margin: 10px;"><t t-esc="state.currentPage_campaigns"/> / <t t-esc="totalPagesCampaigns"/></span>
                                    <button class="btn btn-primary" id="nextPageCampaigns" t-on-click="nextPageCampaigns" t-att-disabled="state.currentPage_campaigns === totalPagesCampaigns"> Next ⏭</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    
                    <div class="grid-stack">
                        
                    </div>
                </div>
                
            </div>
            <footer class="footer">
                    <div class="container text-center">
                        <a href="https://www.pasarelasdepagos.com/venta-multicanal-marketplaces/" target="_blank" style="text-decoration: none;">
                            <span style="color: black; font-size: 11px;">Venta Multicanal Marketplaces 2.0 All Rights Reserved.</span>
                        </a>
                    </div>
                </footer>
        </t>
        <t t-if="state.currentView == 'detail'">
            <div class="container column d-flex" style="margin: 0px;max-width: -webkit-fill-available;">
                <div class="col-6" style="justify-self: flex-start; display: flex; margin:3px">
                    <button class="btn" t-att-class="{'btn-primary': state.activeMetricDetail == 'clicks', 'btn-outline-primary': state.activeMetricDetail != 'clicks'}" style="margin-inline: 10px;" t-on-click="() => changeMetricDetail('clicks')">Clics</button>
                    <button class="btn" t-att-class="{'btn-primary': state.activeMetricDetail == 'prints', 'btn-outline-primary': state.activeMetricDetail != 'prints'}" style="margin-inline: 10px;" t-on-click="() => changeMetricDetail('prints')">Prints</button>
                    <button class="btn" t-att-class="{'btn-primary': state.activeMetricDetail == 'cpc', 'btn-outline-primary': state.activeMetricDetail != 'cpc'}" style="margin-inline: 10px;" t-on-click="() => changeMetricDetail('cpc')">CPC</button>
                    <button class="btn" t-att-class="{'btn-primary': state.activeMetricDetail == 'total_amount', 'btn-outline-primary': state.activeMetricDetail != 'total_amount'}" style="margin-inline: 10px;" t-on-click="() => changeMetricDetail('total_amount')">Income</button>
                    <button class="btn" t-att-class="{'btn-primary': state.activeMetricDetail == 'cost', 'btn-outline-primary': state.activeMetricDetail != 'cost'}" style="margin-inline: 10px;" t-on-click="() => changeMetricDetail('cost')">Costs</button>
                    <button class="btn" t-att-class="{'btn-primary': state.activeMetricDetail == 'acos', 'btn-outline-primary': state.activeMetricDetail != 'acos'}" style="margin-inline: 10px;" t-on-click="() => changeMetricDetail('acos')">ACOS</button>
                </div>
                <div class="col-6" style="display: flex;padding: 0px;justify-content: flex-end;">
                    <select class="custom-select mx-1" t-on-change="handleFilterChangeAdvs" t-model="state.filterTypeDateAdvs" id="dateFilterAdvs" style="width: 150px;">
                        <option value="7">Last 7 days</option>
                        <option value="15">Last 15 days</option>
                        <option value="30">Last 30 days</option>
                        <option value="60">Last 60 days</option>
                        <option value="90">Last 90 days</option>
                    </select>
                </div>
            </div>
            <div class="container d-flex flex-column" style="max-width: 100%;">
                <div class="row flex-grow-1">
                    <div class="grid-stack-item col-lg-12 col-md-12 col-sm-12 mb-3 h-50" gs-w="4" gs-h="3">
                        <div class="grid-stack-item-content card-body" style="min-height: 350px;">
                            <canvas t-ref="chartDetail"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            
            <div class="o_action_manager custom-whatsapp-suite" bis_skin_checked="1" style="overflow: auto !important;">
                <style>
                    .info-icon {
                        display: inline-block;
                        width: 20px;
                        height: 20px;
                        line-height: 20px;
                        text-align: center;
                        border-radius: 50%;
                        background-color:rgb(2, 7, 12);
                        color: white;
                        font-size: 14px;
                        font-weight: bold;
                        cursor: pointer;
                        margin-left: 5px;
                    }

                    
                    .tooltip-container {
                        position: relative;
                        cursor: pointer;
                    }

                    .tooltip-custom {
                        position: absolute;
                        background-color: rgb(255, 255, 255); 
                        color: black;
                        text-align: center;
                        padding: 8px;
                        border-radius: 5px;
                        border: 1px solid black;
                        font-size: 12px;
                        width: 150px;
                        bottom: -115%;
                        left: 50%;
                        transform: translateX(-50%);
                        opacity: 0;
                        visibility: hidden;
                        transition: opacity 0.3s ease-in-out;
                    }

                    .tooltip-container:hover .tooltip-custom {
                        opacity: 1;
                        visibility: visible;
                    }
                </style>
                <div class="o_dashboard_view my-1">
                    <button class="btn btn-secondary mb-2" t-on-click="goBack" style="margin-left: 1%;"> Go Back</button>
                    <div class="container" style="max-width: none !important">
                        <div class="grid-stack-item-content p-3" >
                            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4">
                                <h5 class="mb-0" style="margin: 0px 10px;">Advertisements</h5>
                                <div>
                                    <input type="text" placeholder="Search by title or product..." t-on-input="ev => updateFilterAdvertisement(ev, 'search')" class="form-control mr-2" id="searchInputDetail" style="width: 200px; display: inline-block;"/>
                                    <select class="custom-select mx-1" t-on-change="ev => updateFilterAdvertisement(ev, 'status')" id="statusFilterDetail" style="width: 150px;">
                                        <option value="">All Status</option>
                                        <option value="active">Active</option>
                                        <option value="paused">Paused</option>
                                        <option value="hold">Hold</option>
                                    </select>
                                    <button class="btn btn-primary" id="export_excel" style="margin-bottom: 1%;" t-on-click="exportToExcelAdvertisements">
                                        Export to Excel
                                    </button>
                                </div>
                            </div>
                            <div class="table-responsive" style="width: 100%;"> 
                                <table class="table table-hover" id="table-advertisements">
                                    <thead class="thead-light">
                                        <tr>
                                            <th scope="col" t-esc="'Status'" title="This is Title">Status</th>
                                            <th scope="col" t-esc="'Product'" >Product</th>
                                            <th scope="col" t-esc="'Title'" >Title</th>
                                            <th scope="col" class="tooltip-container">
                                                Prints 
                                                <span class="tooltip-custom">One impression is counted each time the ad is shown.</span>
                                                <span class="info-icon" data-bs-toggle="tooltip">?</span></th>
                                            <th scope="col" class="tooltip-container">
                                                Clics
                                                <span class="tooltip-custom">When a user clicks on your ad, it is counted here.</span>
                                                <span class="info-icon" data-bs-toggle="tooltip">?</span></th>
                                            <th scope="col" class="tooltip-container"> 
                                                CPC
                                                <span class="tooltip-custom">Price paid for each time a user clicks on an ad.</span>
                                                <span class="info-icon" data-bs-toggle="tooltip">?</span></th>
                                            <th scope="col" class="tooltip-container">
                                                Advertising Sales
                                                <span class="tooltip-custom">Amount of advertising sales.</span>
                                                <span class="info-icon" data-bs-toggle="tooltip">?</span></th>
                                            <th scope="col" class="tooltip-container">
                                                Income
                                                <span class="tooltip-custom">Sum of the value of sales obtained from your Product Ad.</span>
                                                <span class="info-icon" data-bs-toggle="tooltip">?</span></th>
                                            <th scope="col" class="tooltip-container">
                                                Cost
                                                <span class="tooltip-custom">The cost corresponds to the sum of the expenses during this period.</span>
                                                <span class="info-icon" data-bs-toggle="tooltip">?</span></th>
                                            <th scope="col" class="tooltip-container">
                                                ACOS
                                                <span class="tooltip-custom">Percentage of investment in advertising over the income obtained.</span>
                                                <span class="info-icon" data-bs-toggle="tooltip">?</span></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="paginatedAdvertisements" t-as="row" t-key="row.name" t-att-data-id="row.id">
                                            <td t-esc="row.status"></td>
                                            <td t-esc="row.product"></td>
                                            <td t-esc="row.title"></td>
                                            <td t-esc="row.prints"></td>
                                            <td t-esc="row.clicks"></td>
                                            <td t-esc="row.cpc"></td>
                                            <td t-esc="row.advertising_items_quantity"></td>
                                            <td t-esc="row.total_amount"></td>
                                            <td t-esc="row.cost"></td>
                                            <td t-esc="row.acos">%</td>
                                        </tr>
                                    </tbody>
                                </table>
                                <div class="pagination-controls">
                                    <button class="btn btn-primary" id="prevPage" t-on-click="prevPageAdvertisements" t-att-disabled="state.currentPage_advertisements === 1">⏮ Previous </button>
                                    <span id="pageNumber" style="margin: 10px;"><t t-esc="state.currentPage_advertisements"/> / <t t-esc="totalPagesAdvertisements"/></span>
                                    <button class="btn btn-primary" id="nextPage" t-on-click="nextPageAdvertisements" t-att-disabled="state.currentPage_advertisements === totalPagesAdvertisements"> Next ⏭</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    
                    <div class="grid-stack">
                        
                    </div>
                </div>
                
            </div>
            <footer class="footer">
                <div class="container text-center">
                    <a href="https://www.pasarelasdepagos.com/venta-multicanal-marketplaces/" target="_blank" style="text-decoration: none;">
                        <span style="color: black; font-size: 11px;">Venta Multicanal Marketplaces 2.0 All Rights Reserved.</span>
                    </a>
                </div>
            </footer>
        </t>
    </t>
</templates>
