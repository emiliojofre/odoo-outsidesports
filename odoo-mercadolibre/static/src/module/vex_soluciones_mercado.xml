    <!-- GRAPH -->
        <div class="o_action_manager custom-whatsapp-suite" style="overflow: auto; max-width: 100%;">
            <div class="o_dashboard_view my-5">
                <div class="d-flex justify-content-between gap-4 flex-wrap" style="row-gap: 10px; padding-top: 20px; margin-left: 20px; margin-right: 20px;">
        
                    <!-- Orders synced today -->
                    <div class="card p-3 text-center" style="min-width: 150px; flex-grow: 1;">
                        <p t-esc="state.orders_number"></p>
                        <h6 class="mt-2" t-esc="'Price score'"></h6>
                    </div>

                    <!-- Total orders -->
                    <div class="card p-3 text-center" style="min-width: 150px; flex-grow: 1;">
                        <p t-esc="state.total_orders"></p>
                        <h6 class="mt-2" t-esc="'Increased Profit'"></h6>
                    </div>

                    <!-- New customers this month -->
                    <div class="card p-3 text-center" style="min-width: 150px; flex-grow: 1;">
                        <p t-esc="state.new_customers_last_month + '%'"></p>
                        <h6 class="mt-2" t-esc="'Profit Margin'"></h6>
                    </div>

                    <!-- Elemento 4 -->
                    <div class="card p-3 text-center" style="min-width: 150px; flex-grow: 1;">
                        <p t-esc="state.total_customers_count"></p>
                        <h6 class="mt-2" t-on-click="customers_view" t-esc="'Total Sales'"></h6>
                    </div>

                    <!-- Elemento 5 -->
                    <div class="card p-3 text-center" style="min-width: 150px; flex-grow: 1;">
                        <p t-esc="state.products_count"></p>
                        <h6 class="mt-2" t-on-click="products_view" t-esc="'Products'"></h6>
                    </div>

                    <!-- Elemento 6 -->
                    <div class="card p-3 text-center" style="min-width: 150px; flex-grow: 1;">
                        <p t-esc="state.questions_count"></p>
                        <h6 class="mt-2" t-on-click="questions_view" t-esc="'Total competitors'"></h6>
                    </div>

                </div>
            </div>
        </div>



