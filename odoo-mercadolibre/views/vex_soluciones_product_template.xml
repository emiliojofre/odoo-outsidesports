<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_only_form_view_product" model="ir.ui.view">
        <field name="name">product.template.view.form.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='detailed_type']" position="before">
                <field name="instance_id" string="Mercado Libre Instance"/>
            </xpath>
            <xpath expr="//group[1]" position="inside">
                <group invisible="1">
                    <field name="store_type" />
                </group>
            </xpath>
            <xpath expr="//button[@name='action_view_sales']" position="after">
                <button name="action_export_product"
                        string="Export Product"
                        type="object"
                        class="btn-secondary"/>
            </xpath>
            <xpath expr="//div[@name='options']" position="replace">
                <div name="options">
                    <span class="d-inline-block">
                        <field name="sale_ok" on_change="1"/>
                        <label for="sale_ok"/>
                    </span>
                    <span class="d-inline-block">
                        <field name="purchase_ok"/>
                        <label for="purchase_ok"/>
                    </span>
                    <span class="d-inline-block">
                        <field name="server_meli"/>
                        <label for="server_meli"/>
                    </span>
                    <span class="d-inline-block" invisible="store_type != 'mercadolibre'">
                        <field name="export_to_meli"/>
                        <label for="export_to_meli"/>
                    </span>
                    <span invisible="store_type != 'mercadolibre'">
                        <field name="is_package" />
                        <label for="is_package"/>
                    </span>
                </div>
            </xpath>
            <xpath expr="//page[@name='invoicing']" position="after">
                <page string="Product Variants" invisible="store_type != 'mercadolibre'">
                    <group >
                        <field name='product_variant_ids'/>
                    </group>
                </page>
                <page name="price_history" string="Price History" invisible="store_type != 'mercadolibre'">
                    <!-- <div class="row">
                        <div class="col-6">
                            <label for="date_from">Start Date</label>
                            <field name="date_from" nolabel="1"/>
                        </div>
                        <div class="col-6">
                            <label for="date_to">End Date</label>
                            <field name="date_to" nolabel="1"/>
                        </div>
                    </div> -->
                    <field name="evolution_data_ids">
                        <tree editable="bottom" create="0" edit="0">
                            <field name="change_date"/>
                            <field name="old_price"/>
                            <field name="new_price"/>                           
                        </tree>
                    </field>
                </page>           
                <!-- <page name="competence_historyyy" string="Competence Price Historyyy" invisible="store_type != 'mercadolibre'">
                    <field name="create_date" widget="date"/>
                </page>     -->
                <page name="competence_history" string="Competence Price History" invisible="store_type != 'mercadolibre'">                    
                    <!-- <div class="row">
                        <div class="col-6">
                            <label for="date_from">Start Date</label>
                            <field name="date_from" nolabel="1"/>
                        </div>
                        <div class="col-6">
                            <label for="date_to">End Date</label>
                            <field name="date_to" nolabel="1"/>
                        </div>
                    </div> -->

                    <field name="competitor_price_history_ids">
                        <tree editable="false" create="0" edit="0" delete="0">
                            <field name="name"/>
                            <field name="price"/>
                            <field name="currency_id"/>
                            <!-- <field name="link"  widget="url"/> -->
                            <field name="url_html" widget="html"/>
                            <field name="condition"/>
                            <field name="create_date"/>
                            <field name="write_date"/>
                            <!-- <field name="competence_image" widget="image" string="Image"/>
                            <field name="name" string="Competitor Name"/>
                            <field name="link" string="Competitor Link" widget="url"/>
                            <field name="competence_actual_price" string="Price"/>
                            <field name="write_date" string="Last Updated" widget="datetime"/> -->
                        </tree>
                    </field>
                </page>
                <page name="publications" string="Publicaciones" invisible="store_type != 'mercadolibre'">
                    <field name="group_ids" create="0">
                        <tree>
                            <field name="image" widget="image" string="Image"/>
                            <field name='name'/>
                            <field name="url" widget="url"/>
                            <field name="num_publication" />
                            <field name="price" />
                            <field name="quantity" />
                            <field name="meli_category_code" />
                            <field name="action_export"/>
                            <field name="export_to_meli" string="Export to MELI?" class="text-right" />                            
                        </tree>
                    </field>
                </page>
                <page name="meli_info" string="MELI INFO">
                    <group >
                        <field name="site_id" invisible="1"/>
                        <field name='meli_listing_type' options="{'no_open': True, 'no_create': True}"/>
                        <field name='meli_condition_id' options="{'no_open': True, 'no_create': True}"/>
                        <!-- <field name='permalink' widget="url"/> -->
                        <field name='meli_thumbnail' widget="url"/>
                        <field name='meli_buying_mode_id' options="{'no_open': True, 'no_create': True}"/>
                        <field name='meli_category' options="{'no_open': True, 'no_create': True}"/>
                        <field name='inventory_id'/>  
                        <!-- SUPLEFIT_LOGIC--><field name="warehouse_location"  invisible="store_type != 'mercadolibre'"/>
                    </group>
                </page>

                <page string="MELI Score">
                    <field name="performance_score_ids" nolabel="1">
                        <tree editable="bottom">
                            <field name="name"/>
                            <field name="sub_performance_score"  widget="handle"/>
                            <field name="sub_performance_level" decoration-danger="sub_performance_score &lt; 60"
                                       decoration-warning="sub_performance_score &lt; 90"
                                       decoration-success="sub_performance_score &gt;= 90"/>
                        </tree>
                    </field>
                </page>

                <page name="unit_products" string="Productos Incluidos en el Paquete" invisible="is_package == False">
                    <field name="product_unit_ids" nolabel="1" mode="tree,kanban">
                        <tree editable="bottom">
                                <control>
                                    <create name="add_product_control" string="Add a product"/>
                                </control>                        
                            <field name="product_id"></field>
                            <field name="permalink" widget="url" readonly="1"></field>
                            <field name="quantity"></field>                                
                        </tree>
                    </field>
                </page>
            </xpath>
            <xpath expr="//field[@name='product_tooltip']" position="after">
                <field name="walmart_price" string="Walmart Price"/>
                <field name="amazon_price" string="Amazon Price"/>
                <field name="mercado_libre_price" string="Mercado Libre Price"/>
                <field name="shopify_price" string="Shopify Price"/>
                <field name="upc" string="UPC"/>
                <!-- <field name="description"/> -->
            </xpath>

            <xpath expr="//field[@name='description']" position="after">
                <group string = "Descripción del Producto">
                    <field name="description_product" nolabel="1" placeholder="Escribe aquí..."
                        widget="html" style="max-width: 4000%; width: 4000%; white-space: normal; overflow-wrap: break-word; white-space: normal; text-align: justify; word-wrap: break-word; overflow: hidden;"/>
                </group >
            </xpath>

            <xpath expr="//field[@name='description_product']" position="after">
                
                <group string = "Optimiza la Descripción con Inteligencia Artificial" colspan="2">
                    <field name="request_prompt" placeholder="Ejemplo: Optimiza la descripción y agrega más detalles" style="max-width: 4000%; width: 4000%; white-space: normal; overflow-wrap: break-word; white-space: normal; text-align: justify; word-wrap: break-word; overflow: hidden;"/>
                    <field name="description_optimized"/>
                    <!-- <field name="image_no_bg" widget="image" class="oe_avatar"/> -->
                    <!-- <button name="remove_background_odoo" type="object" string="Quitar Fondo" class="oe_highlight"/> -->
                    <!-- Añadimos un contenedor con alineación a la derecha -->
                    <div style="text-align: right; width: 100%;">
                        <button name="action_optimize_description"
                                type="object"
                                class="btn-primary"
                                string="Optimizar"
                                style="margin-left: auto; margin-right: 0;"/>
                    </div>
                </group >
            </xpath>
            <xpath expr="//field[@name='default_code']" position="after">        
                <field name="ml_reference" string="MELI SKU"  invisible="store_type != 'mercadolibre'"/>
                <field name="ml_publication_code" invisible="store_type != 'mercadolibre'"/>
                <field name="meli_category_code" invisible="store_type != 'mercadolibre'" />
                <field name="meli_status" invisible="store_type != 'mercadolibre'"/>
                <field name="action_export" invisible="store_type != 'mercadolibre'"/>
                <field name="attachment_id" invisible="store_type != 'mercadolibre'" /> 
            </xpath>
        </field>
    </record>

    <record id="product_template_form_view_product" model="ir.ui.view">
        <field name="name">product.template.form.view.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='pricing']" position="after">
                <!-- <field name="price_score" invisible="store_type != 'mercadolibre'" readonly="1"/>  -->
                <field name="price_score_badge" readonly="1">
                    <attrs>
                        <invisible>
                            <neq field="store_type" value="mercadolibre"/>
                        </invisible>
                    </attrs>
                </field>
            </xpath> 
            <xpath expr="//div[@name='standard_price_uom']" position="after">
                <field name="market_fee" string="MELI fee" readonly="1">
                    <attrs>
                        <invisible>
                            <neq field="store_type" value="mercadolibre"/>
                        </invisible>
                    </attrs>
                </field>
            </xpath> 
        </field>
    </record>
    <record id="product_template_tree_view_product" model="ir.ui.view">
        <field name="name">product.template.view.tree.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_code']" position="after">
                <field name="ml_reference" string="ML SKU"/>
                <field name="ml_publication_code" string="ML Publication"/>
                <!-- <field name="warehouse_location" string="Bodega"/> -->
                <field name="meli_category_code" string="ML Category"/>
                <field name='listing_type_id' decoration-warning="listing_type_id=='gold_special'" decoration-success="listing_type_id=='gold_pro'"/>
                <field name='condition'/>
                <field name='buying_mode'/>
                <!-- <field name='inventory_id'/>   -->             
            </xpath>
            <xpath expr="//field[@name='standard_price']" position="after">
                <field name="market_fee" string="MercadoLibre commission"/>
                <field name="x_profit_margin"/>
            </xpath>
            <xpath expr="//field[@name='default_code']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='product_tag_ids']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='responsible_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>        
            <!-- <xpath expr="//field[@name='standard_price']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>          -->
            <xpath expr="//field[@name='virtual_available']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath> 
            <xpath expr="//field[@name='uom_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>           
            <xpath expr="//field[@name='qty_available']" position="attributes">
                <attribute name="string">Stock on hand</attribute>
            </xpath>
            <xpath expr="//field[@name='list_price']" position="attributes">
                <attribute name="string">Public price</attribute>
            </xpath>
            <xpath expr="//field[@name='standard_price']" position="attributes">
                <attribute name="string">Cost price</attribute>
            </xpath>
            <!-- <xpath expr="//field[@name='list_price']" position="before">
                <field name="price_score_badge" widget="html"/>
            </xpath>   -->
            <xpath expr="//field[@name='product_tag_ids']" position="after">
                <field name="performance_score" widget="handle" /> 
                <field name='performance_level' decoration-danger="performance_score &lt; 60"
                                       decoration-warning="performance_score &lt; 90"
                                       decoration-success="performance_score &gt;= 90"/>
                <field name="price_score_badge" widget="html"/>
            </xpath>                                                  
        </field>
    </record>
