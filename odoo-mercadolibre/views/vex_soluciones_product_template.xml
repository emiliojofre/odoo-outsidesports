        </field>
    </record> -->
    <record id="product_template_units_view_form" model="ir.ui.view">
        <field name="name">product_template_units.view.form</field>
        <field name="model">product.template.units</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <group>
                        <field name="product_id" />
                        <field name="meli_code" />
                        <field name="quantity" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="product_template_tree_view_product_mercadolibre" model="ir.ui.view">
        <field name="name">product.template.tree.view.mercadolibre</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <tree string="Mercadolibre products">
                <field name="name"/>
                <field name="ml_reference" string="ML SKU"/>
                <field name="ml_publication_code" string="ML Publication"/>
                <field name="meli_category_code" string="ML Category"/>
                <field name="listing_type_id" decoration-warning="listing_type_id=='gold_special'" decoration-success="listing_type_id=='gold_pro'"/>
                <field name="condition"/>
                <field name="buying_mode"/>
                <field name="performance_score" column_invisible="1" /> 
                <field name='performance_level' decoration-danger="performance_score &lt; 60"
                                       decoration-warning="performance_score &lt; 90"
                                       decoration-success="performance_score &gt;= 90"/>
                <field name="price_score_badge"/>
                <field name="list_price" string="Public price"/>
                <field name="standard_price" string="Cost price"/>
                <field name="market_fee" string="MercadoLibre commission"/>
                <field name="x_profit_margin"/>
                <field name="qty_available" string="Stock on hand"/>
                <field name="meli_status"/>
            </tree>
        </field>
    </record>

    <record id="product_product_tree_view_product_mercadolibre" model="ir.ui.view">
        <field name="name">product.product.tree.inherit</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_product_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='uom_id']" position="after">
                <field name="ml_variation_id"/>
            </xpath>
        </field>
    </record>

    <record id="product_template_search_view_mercadolibre" model="ir.ui.view">
        <field name="name">product.template.search.view.mercadolibre</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <search string="Mercadolibre Search View">
                <field name="name"/>
                <field name="instance_id"/>
                <filter name="search_default_instance_filter"
                        string="MercadoLibre Instance Active"
                        domain="[('instance_id', '=', context.get('default_instance_id', False))]"
                />
            </search>
        </field>
    </record>

