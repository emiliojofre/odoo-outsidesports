<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_order_line_tree_group_by_category" model="ir.ui.view">
        <field name="name">sale.order.line.tree.group.by.category</field>
        <field name="model">sale.order.line</field>
        <field name="inherit_id" ref="sale.view_order_line_tree"/>
        <field name="arch" type="xml">
            <!-- Usamos XPath para localizar e insertar campos dentro del árbol existente -->
            <xpath expr="//tree" position="inside">
                <field name="product_categ_id" string="Category"/>
                <field name="price_total" string="Total"/>
            </xpath>
        </field>
    </record>
</odoo>
