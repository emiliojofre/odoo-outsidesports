<odoo>
    <record id="view_product_pricing_kanban" model="ir.ui.view">
        <field name="name">product.pricing.kanban</field>
        <field name="model">mercado.libre.product</field>
        <field name="arch" type="xml">
            <kanban>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card">
                            <div class="o_kanban_content">
                                <strong><t t-esc="record.name"/></strong>
                              
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>
