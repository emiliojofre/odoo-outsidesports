<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Definir la vista del wizard -->
    <record id="view_product_export_wizard_form" model="ir.ui.view">
        <field name="name">product.export.wizard.form</field>
        <field name="model">product.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Exportación Masiva de Productos">
                <group>
                    <!-- Primera columna: Productos seleccionados en Odoo -->
                    <group>
                        <field name="instance_id" required="1"/>
                        <field name="product_ids" widget="many2many_tags"/>
                    </group>
                    <!-- Segunda columna: Excel -->
                    <group>
                        <field name="file" widget="attachment" filename="file_name"/>
                        <field name="support_drive_download" />
                    </group>
                </group>
                <footer>
                    <!-- Botones para la acción -->
                    <button string="Confirmar" type="object" name="confirm_action" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                    <button string="Descargar Drive" type="object" name="download_image_from_drive" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Definir la acción que abre el wizard -->
    <record id="action_product_export_wizard" model="ir.actions.act_window">
        <field name="name">Exportación Masiva de Productos</field>
        <field name="res_model">product.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_product_export_wizard_form"/>
        <field name="target">new</field>        <!-- Esto asegura que se abra como modal -->
    </record>
</odoo>
