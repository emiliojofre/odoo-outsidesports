    <record id="vex_category_search_view" model="ir.ui.view">
        <field name="name">vex.category.search</field>
        <field name="model">vex.category</field>
        <field name="arch" type="xml">
            <search>
                <field name="instance_id"/>
                <filter name="instance_filter" string="Mercadolibre Instance Active"
                    domain="[('instance_id', '=', context.get('default_instance_id', False))]"
                />     
            </search>
        </field>
    </record>
</odoo>
