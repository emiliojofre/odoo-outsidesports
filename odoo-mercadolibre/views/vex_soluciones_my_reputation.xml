<odoo>
    <record id="view_my_reputation_tree" model="ir.ui.view">
        <field name="name">vex.soluciones.my.reputation.tree</field>
        <field name="model">vex_soluciones.my_reputation</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="level_id"/>
                <field name="power_seller_status"/>
                <field name="total_sales"/>
                <field name="cancellations"/>
                <field name="ratings_positive"/>
                <field name="ratings_neutral"/>
                <field name="ratings_negative"/>
                <field name="sales_last_60_days"/>
                <field name="claims_rate"/>
                <field name="delayed_orders"/>
                <field name="canceled_orders"/>
            </tree>
        </field>
    </record>

    <record id="view_my_reputation_form" model="ir.ui.view">
        <field name="name">vex.soluciones.my.reputation.form</field>
        <field name="model">vex_soluciones.my_reputation</field>
        <field name="arch" type="xml">
            <form string="Reputación">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>    
                            <field name="level_id"/>
                            <field name="power_seller_status"/>
                            <field name="total_sales"/>
                            <field name="cancellations"/>
                            <field name="sales_last_60_days"/>
                        </group>
                        <group>
                            <field name="ratings_positive"/>
                            <field name="ratings_neutral"/>
                            <field name="ratings_negative"/>
                            <field name="claims_rate"/>
                            <field name="delayed_orders"/>
                            <field name="canceled_orders"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="vex_soluciones_my_reputation_search_view" model="ir.ui.view">
        <field name="name">vex_soluciones.my_reputation.search</field>
        <field name="model">vex_soluciones.my_reputation</field>
        <field name="arch" type="xml">
            <search>
                <field name="instance_id"/>
                <filter name="instance_filter" string="Mercadolibre Instance Active"
                    domain="[('instance_id', '=', context.get('default_instance_id', False))]"
                />     
            </search>
        </field>
    </record>
</odoo>
