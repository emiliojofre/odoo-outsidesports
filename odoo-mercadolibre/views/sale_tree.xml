<odoo>
 <record id="view_sale_order_tree_inherit_repurchase_rate" model="ir.ui.view">
    <field name="name">sale.order.tree.repurchase.rate</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale.view_quotation_tree"/>
    <field name="arch" type="xml">
        <xpath expr="//field[@name='partner_id']" position="after">
            <field name="repurchase_rate"/>
               </xpath>
    </field>
</record>

</odoo>

