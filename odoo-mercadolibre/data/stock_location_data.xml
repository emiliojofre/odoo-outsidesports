<odoo>
    <data noupdate="1">
        <record id="ml_stock" model="stock.location">
            <field name="name">ml_stock</field>
            <field name="location_id" ref="stock.stock_location_stock"/>
            <field name="usage">internal</field>
        </record>
        <record id="stock_location_mercadolibre" model="stock.location">
            <field name="name">MERCADOLIBRE</field>
            <field name="location_id" ref="stock.stock_location_stock"/>
            <field name="usage">internal</field>
        </record>
        <record id="stock_location_ml_full" model="stock.location">
            <field name="name">ML FULL</field>
            <field name="location_id" ref="stock_location_mercadolibre"/>
            <field name="usage">internal</field>
        </record>
        <record id="stock_location_ml_not_full" model="stock.location">
            <field name="name">ML NOT FULL</field>
            <field name="location_id" ref="stock_location_mercadolibre"/>
            <field name="usage">internal</field>
        </record>
    </data>
</odoo>
