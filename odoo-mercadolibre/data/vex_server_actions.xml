<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Definir la Acción Servidor -->
    <record id="action_custom_sale_action" model="ir.actions.server">
        <field name="name">Imprimir guia de envio</field>
        <field name="model_id" ref="sale.model_sale_order"/> <!-- Modelo donde se aplica la acción -->
        <field name="binding_model_id" ref="sale.model_sale_order"/> <!-- Modelo donde se aplica la acción -->
        <field name="state">code</field>
        <field name="code">
            action = records.print_guides()
        </field>
    </record>

</odoo>
