<odoo>
    <data noupdate="1" >
    <!-- Cron para automatic pricing -->
        <record id="vex_soluciones_ir_cron_automatic_pricing" model="ir.cron">
            <field name="name">CRON AUTOMATICO PRICING</field>
            <field name="model_id" ref="model_vex_automatic_pricing"/>
            <field name="state">code</field>
            <field name="code">model.supervise_competitors()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field eval="False" name="doall"/>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
    
