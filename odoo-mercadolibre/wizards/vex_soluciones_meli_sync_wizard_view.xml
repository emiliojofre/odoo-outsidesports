<odoo>
  <record id="view_meli_sync_wizard_form" model="ir.ui.view">
    <field name="name">meli.sync.wizard.form</field>
    <field name="model">meli.sync.wizard</field>
    <field name="arch" type="xml">
      <form string="Sincronizar MercadoLibre">
        <group>
          <field name="site_id"/>
          <field name="sync_options"/>
          <field name="sync_categories"/>
        </group>
        <footer>
          <button name="action_sync" type="object" class="btn-primary" string="Sincronizar"/>
          <button string="Cancelar" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

</odoo>
