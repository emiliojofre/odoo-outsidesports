<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_import_excel_wizard_form" model="ir.ui.view">
        <field name="name">import.excel.wizard.form</field>
        <field name="model">import.excel.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Excel Data">
                <group>
                    <field name="excel_file" widget="binary"/>
                    <field name="file_name"/>
                    <field name="import_type"/>
                </group>
                <footer>
                    <button string="Import" type="object" name="action_import_file" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_import_excel_wizard" model="ir.actions.act_window">
        <field name="name">Import Excel Data</field>
        <field name="res_model">import.excel.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_import_excel_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>
