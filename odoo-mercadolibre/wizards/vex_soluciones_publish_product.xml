<odoo>
    <record id="view_vex_publish_product_wizard_form" model="ir.ui.view">
        <field name="name">vex.publish.product.wizard.form</field>
        <field name="model">vex.publish.product.wizard</field>
        <field name="arch" type="xml">
            <form string="Publicar Producto en MercadoLibre">
                <group>
                    <field name="instance_id"/>
                    <field name="name" readonly="1"/>
                    <field name="image_1920" widget="image" readonly="1"/>
                    <field name="meli_thumbnail" />
                </group>
                <group string="Datos requeridos ML">
                    <group>
                        <field name="meli_title"/>
                        <field name="meli_category_vex"/>
                        <field name="meli_currency_id"/>
                        <field name="meli_available_quantity"/>
                        <field name="meli_buying_mode"/>
                        <field name="meli_condition"/>
                    </group>
                    <group>
                        <field name="meli_listing_type"/>
                        <field name="meli_base_price" />
                        <field name="meli_warranty_type" />
                        <field name="meli_warranty_time" />
                    </group>
                </group>
                <group string="Descripción MercadoLibre">
                    <field name="meli_description" widget="text" placeholder="Agrega la descripción del producto"/>
                </group>
                <group string="Imágenes MercadoLibre 1">
                    <field name="meli_pictures_ids">
                        <tree>
                            <field name="url" />
                            <field name="secure_url"/>
                        </tree>
                    </field>
                </group>
                <group string="Atributos MercadoLibre 2">
                    <field name="meli_attribute_ids">
                        <tree editable="bottom">
                            <field name="meli_attribute_id"/>
                            <field name="meli_attribute_name"/>
                            <field name="meli_value_id"/>
                            <field name="meli_value_name"/>
                        </tree>
                    </field>
                </group>
                <footer>
                    <button string="Publicar" type="object" name="action_publish" class="btn-primary"/>
                    <button string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>