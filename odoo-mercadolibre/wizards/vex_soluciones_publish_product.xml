<odoo>
    <record id="view_vex_publish_product_wizard_form" model="ir.ui.view">
        <field name="name">vex.publish.product.wizard.form</field>
        <field name="model">vex.publish.product.wizard</field>
        <field name="arch" type="xml">
            <form string="Publicar en MercadoLibre">
                <!-- Campo invisible para que el domain funcione -->
                    

                <!-- Información del producto -->
                <group col="2">
                    <group string="Información del producto">
                        <field name="instance_id"/>
                        <field name="name" readonly="1"/>
                        <field name="meli_thumbnail" readonly="1"/>
                        <field name="image_1920" widget="image" 
                           options="{'size': (90, 90)}" class="oe_avatar" readonly="1"/>
                    </group>
                    <group string="Detalle del Precio">
                        <field name="percentaje_fee" />
                        <field name="fixed_fee" />
                        <field name="gross_amount" class="oe_inline oe_bold" readonly="1"/>
                        <field name="meli_base_price" />
                    </group>
                </group>

                <!-- Datos requeridos -->
                <group string="Datos requeridos" col="2">
                    <group>
                        <field name="meli_title"/>
                        <field name="meli_category_vex"/>
                        <field name="meli_category_id"/>
                        <field name="meli_currency"/>
                        <field name="meli_available_quantity"/>
                        <field name="meli_buying_mode"/>
                        <field name="meli_condition"/>
                    </group>
                    <group>
                        <field name="meli_listing_type"/>
                        <field name="meli_warranty_type"/>
                        <field name="meli_warranty_time" placeholder="Escribe el tiempo de garantía (30 días o 1 mes)"/>
                        <field name="meli_logistic_type"/>
                    </group>
                </group>

                <!-- Descripción -->
                <group string="Descripción">
                    <field name="meli_description" widget="text"
                        placeholder="Escribe la descripción del producto"/>
                </group>

                <!-- Imágenes -->
                <group string="Imágenes">
                    <field name="meli_pictures_ids">
                        <tree>
                            <field name="url" invisible="1"/>
                            <field name="secure_url"/>
                        </tree>
                    </field>
                </group>

                <!-- Atributos -->
                <group string="Atributos">
                    <field name="meli_attribute_ids">
                        <tree editable="bottom">
                            <field name="meli_category_id" invisible="0"/>
                            <field name="meli_attribute_ref_id" domain="[('meli_category_id','=',meli_category_vex)]"/>
                            <field name="meli_attribute_name" readonly="1"/>
                            <field name="meli_values_id" domain="[('attribute_id','=', meli_attribute_ref_id)]"/>
                            <field name="meli_value_name" attrs="{'readonly': [('meli_values_id','!=',False)]}"/>
                        </tree>
                    </field>
                </group>
                <!-- Botones -->
                <footer>
                    <button string="Publicar" type="object" 
                            name="action_publish" class="btn-primary"/>
                    <button string="Cancelar" special="cancel"/>
                </footer>

            </form>
        </field>
    </record>

    <record id="view_vex_meli_attribute_value_tree_wizard" model="ir.ui.view">
        <field name="name">vex.meli.attribute.value.tree.wizard</field>
        <field name="model">vex.meli.attribute.value</field>
        <field name="arch" type="xml">
            <tree>
                <field name="meli_value_name"/>
                <field name="attribute_id"/>
                <field name="meli_value_id"/>
            </tree>
        </field>
    </record>

</odoo>
