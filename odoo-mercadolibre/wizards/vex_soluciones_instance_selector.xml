<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_instance_selector_wizard" model="ir.ui.view">
        <field name="name">instance.selector.wizard.form</field>
        <field name="model">instance.selector.wizard</field>
        <field name="arch" type="xml">
            <form string="Select Instance">
                <group>
                    <field name="instance_id" widget="many2one" domain="[('store_type','=','mercadolibre')]"/>
                </group>
                <footer>
                    <button name="apply_instance" string="Apply" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
