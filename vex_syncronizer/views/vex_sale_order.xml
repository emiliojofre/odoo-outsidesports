<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_order_form_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.meli</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='partner_details']" position="inside">
                <field name="instance_id" readonly="0"/>
                <field name="marketplace_ids" widget="many2many_tags" readonly="1" options="{'color_field': 'color'}"/>
            </xpath>
        </field>
    </record>

</odoo>
