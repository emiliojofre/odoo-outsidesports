<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_template_form_meli" model="ir.ui.view">
        <field name="name">product.template.form.inherit.meli</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='detailed_type']" position="before">
                <field name="instance_id"/>
                <field name="marketplace_ids" widget="many2many_tags" readonly="1" options="{'color_field': 'color'}"/>
            </xpath>
        </field>
    </record>

</odoo>
