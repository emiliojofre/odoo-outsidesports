<odoo>
    <data>
        <record id="analytic_report_view" model="ir.ui.view">
            <field name="inherit_id" ref="account.report_generalledger"/>
            <field name="arch" type="xml">
                <xpath expr="//table[@class='table table-condensed']/thead" position="replace">
                    <tr class="text-center">
                        <th>Fecha</th>
                        <th>Diario</th>
                        <th>Empresa</th>
                        <th>Ref</th>
                        <th>Movimiento</th>
                        <th>Descripción</th>
                        <th>Debe</th>
                        <th>Haber</th>
                        <th>Saldo</th>
                        <th groups="base.group_multi_currency">Moneda</th>
                    </tr>
                </xpath>
            </field>
        </record>

        <record model="ir.actions.act_window" id="analytic_report_window">
            <field name="name">Libro Analitico</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">account.report.general.ledger</field>
            <field name="view_mode">tree,form,qweb</field>
        </record>
    </data>
</odoo>