<odoo>
    <data>
        <record id="checking_balance_report_view" model="ir.ui.view">
            <field name="inherit_id" ref="account.report_trialbalance"/>
            <field name="arch" type="xml">
                <!--<xpath expr="//table[@class='table table-condensed']/thead/tr/th[3]" position="before">
                    <th>Saldo Anterior</th>
                </xpath>
                <xpath expr="//table[@class='table table-condensed']/tbody/tr/td[3]" position="before">
                    <td class="text-right">
                        <span t-att-style="style" t-esc="account['balance']" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                    </td>
                </xpath>-->
                <xpath expr="//table[@class='table table-condensed']/tbody/tr" position="after">
                    <tr>
                        <td></td>
                        <td></td>
                        <t t-set="debit_total" t-value="sum([account['debit'] for account in Accounts])"/>
                        <td class="text-right">
                             <span t-att-style="style" t-esc="debit_total" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                        </td>
                        <t t-set="credit_total" t-value="sum([account['credit'] for account in Accounts])"/>
                        <td class="text-right">
                             <span t-att-style="style" t-esc="credit_total" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                        </td>
                        <t t-set="balance_total" t-value="sum([account['balance'] for account in Accounts])"/>
                        <td class="text-right">
                             <span t-att-style="style" t-esc="balance_total" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/>
                        </td>
                    </tr>
                </xpath>
            </field>
        </record>

        <record model="ir.actions.act_window" id="checking_balance_report_window">
            <field name="name">Balance de Comprobacion</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">account.balance.report</field>
            <field name="view_mode">tree,form,qweb</field>
        </record>
    </data>
</odoo>