        <template id="products_categories" inherit_id="website_product_brands.wk_product_brand_page" active="False" customize_show="True" name="eCommerce Categories">
            <xpath expr="//div[@id='products_grid_before']" position="before">
                <t t-set="enable_left_column" t-value="True"/>
            </xpath>
            <xpath expr="//div[@id='products_grid_before']" position="inside">
                <button type="button" class="btn btn-link d-lg-none"
                    data-target="#wsale_products_categories_collapse" data-toggle="collapse">
                    Show categories
                </button>
                <div class="collapse d-lg-block" id="wsale_products_categories_collapse">
                    <ul class="nav nav-pills flex-column mb-2">
                        <li class="nav-item">
                            <a t-att-href="keep('/product/brand/%s' % wk_brand.id, category=0)" t-attf-class="nav-link #{'' if category else 'active'} o_not_editable">All Products</a>
                        </li>
                        <t t-foreach="categories" t-as="c">
                            <t t-call="website_sale.categories_recursive" />
                        </t>
                    </ul>
                </div>
            </xpath>
        </template>

