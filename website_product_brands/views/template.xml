    <data>

    <template id="inherited_website_sale_cart_website_product_brands_wk" name="website product brand" inherit_id="website_sale.product"  active="True" >
      <xpath expr="//div[hasclass('js_main_product')]" position="after">
                <t t-if="product.product_brand_id">
                    <hr/>
                    <b>SKU : <span t-field="product.default_code" class="text-muted"/></b>
                    <br/>
                    <b>PVP: <span t-field="product.product_tmpl_pvp" class="text-muted"/></b>
                    <br/>
                    <b>Marca : <span t-field="product.product_brand_id" class="text-muted"/></b>
                </t>
      </xpath>
    </template>
    <template id="disable_product_default_codes" inherit_id="eq_website_default_code.product_default_codes" active="False"/>

    <template id="inherit_website_sale_o_wsale_offcanvas" inherit_id="website_sale.o_wsale_offcanvas">
        <xpath expr="//form[@t-if='opt_wsale_attributes or opt_wsale_attributes_top']/t" position="after">
            <div class="accordion-item">
                <h2 id="o_wsale_offcanvas_orderby_header" class="accordion-header mb-0">
                    <button class="o_wsale_offcanvas_title accordion-button border-top rounded-0 collapsed"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#o_wsale_offcanvas_brands"
                            aria-expanded="false"
                            aria-controls="o_wsale_offcanvas_brands">
                            <b>Marca</b>
                    </button>
                </h2>
                <div id="o_wsale_offcanvas_brands"
                        class="accordion-collapse collapse"
                        aria-labelledby="o_wsale_offcanvas_orderby_header">
                    <div class="accordion-body pt-0">
                        <div class="list-group list-group-flush">
                            <a t-foreach="brand_rec" t-as="b" role="menuitem">
                                <label>
                                    <input type="checkbox" name="attrib_brand" class="form-check-input" t-att-id="'%s-%s' % (b.id,b.id)" t-att-value="'%s-%s' % (b.id,b.id)" t-att-checked="'checked' if b.id in brand_set else None"/>
                                    <span style="font-weight: normal" t-field="b.name"/>

                                </label>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </template>
    
    <template id="wk_horizontal_brands" name="Brand list" inherit_id="website_sale.products"  active="True" customize_show="True" >
      <xpath expr="//div[hasclass('products_pager')]" position="after">
          <div class = "horizontal_category" >
            <div class="row">
              <div class="col-md-12">
                <center>
                  <ul class="list-inline nav nav-pills justify-content-center">
                    <t t-set="wk_brands"
                      t-value="brand_set and website.get_wk_brands(brand_set)"/>
                    <li class="horizontal_category_unlink_list" style="display:none" >
                      <ul class="list-inline nav nav-pills justify-content-center" t-if='wk_brands'>

                          <t t-foreach="wk_brands" t-as="b">
                          <li t-att-class="'active mr8 mb8' if b.id == int(brand or 0) else ' mr8 mb8'">
                          <a href="#" class="btn btn-primary wk_brand" t-att-data-wk_brand='b.id'> <t t-esc="b.name"/>
                                <i class="fa fa-trash" ></i>
                            </a>
                          </li>
                          </t>
                      </ul>
                    </li>
                  </ul>
              </center>
              </div>
            </div>
          </div>
      </xpath>
    </template>

    <template id="products_attributes" inherit_id="website_sale.products"  priority="100"  name="Product Brand's Filters" active="True" customize_show="True">
        <xpath expr="//aside[@id='products_grid_before']" position="before">
            <t t-set="enable_left_column" t-value="True"/>
        </xpath>
        <xpath expr="//aside[@id='products_grid_before']//form" position="inside">
                <ul t-if="brand_rec" class="nav nav-pills nav-stacked mt16">
                    <li>
                        <t t-set="filter_brand" t-value="str()"/>
                         <t t-foreach="brands or []" t-as="b">
                          <t t-set="filter_brand" t-value="filter_brand+str(b.id)"/>
                        </t>
                          <div><b>Marca</b></div >
                           <div t-att-data-brand_set='brand_set' class="products_brands_filter" t-attf-data-brands="#{filter_brand}">
                          <ul class="nav nav-pills nav-stacked flex-column">
                             <t t-foreach="brand_rec" t-as="b">
                               <li>
                                <label>
                                  <input type="checkbox" name="attrib_brand"
                                    t-att-value="'%s-%s' % (b.id,b.id)"
                                    t-att-checked="'checked' if b.id in brand_set else False"
                                    t-attf-data-brand="#{b.id}"/>
                                  <span style="font-weight: normal" t-field="b.name"/>

                                </label>
                              </li>
                            </t>
                        </ul>
                        </div>
                    </li>
              </ul>
          </xpath>
    </template>

    <template id="inherited_products_description_website_product_brands" inherit_id="website_sale.products_description"  active="True"  >
      <xpath expr="//div[hasclass('oe_subdescription')]" position="inside">
            <b t-if='product.product_brand_id'>Marca:<span t-field="product.product_brand_id" class="text-muted"/></b>
      </xpath>
    </template>

    <template id="wk_header_brand" inherit_id="website.template_header_default" name="Header Shop Brands Link">
        <xpath expr="//t[@t-foreach='website.menu_id.child_id']" position="after">
                <li class="nav-item oe_sale_brands">
                    <a href="/shop/brands" class="nav-link">
                        Marca
                    </a>
                </li>
        </xpath>
    </template>
    <template id="wk_brands_page" name="Brands Page">
      <t t-call="website.layout">
            <t t-set="additional_title"></t>
            <div id="wrap" class="js_sale">
                <div class="oe_structure" id="oe_structure_website_sale_products_1"/>
                <div class="container oe_website_sale">
                    <div class="products_pager form-inline flex-md-nowrap justify-content-between justify-content-md-center">
                        <div class="mt-2 ml-md-2" style="padding:0px">
                            <form t-att-action="keep('/shop/brands', search=0)" method="get" t-att-class="search_class">
                                <t t-call="website.website_search_box"/>
                            </form>
						</div>
                        <t t-call="website.pager">
                            <t t-set="_classes">mt-2 ml-md-2</t>
                        </t>
                    </div>
                    <div class="row o_wsale_products_main_row">
                        <div t-if="enable_left_column" id="products_grid_before" class="col-lg-3"/>
                        <div id="products_grid" t-attf-class="col">
                            <div t-if="bins" class="o_wsale_products_grid_table_wrapper">
                                <table class="table table-borderless m-0" t-att-data-ppg="ppg" t-att-data-ppr="ppr">
                                    <colgroup t-ignore="true">
                                        <!-- Force the number of columns (useful when only one row of (x < ppr) products) -->
                                        <col t-foreach="ppr" t-as="p"/>
                                    </colgroup>
                                    <tbody>
                                        <tr t-foreach="bins" t-as="tr_brands">
                                            <t t-foreach="tr_brands" t-as="td_brands">
                                                <t t-if="td_brands">
                                                    <t t-set="wk_brand" t-value="td_brands['product']" />
                                                    <td t-att-colspan="td_brands['x'] != 1 and td_brands['x']"
                                                        t-att-rowspan="td_brands['y'] != 1 and td_brands['y']"
                                                        t-attf-class="oe_product">
                                                        <div t-attf-class="o_wsale_product_grid_wrapper o_wsale_product_grid_wrapper_#{td_brands['x']}_#{td_brands['y']}">
                                                            <t t-call="website_product_brands.wk_brands_item">
                                                                <t t-set="product_image_big" t-value="td_brands['x'] + td_brands['y'] &gt; 2"/>
                                                            </t>
                                                        </div>
                                                    </td>
                                                </t>
                                                <td t-else=""/>
                                            </t>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <t t-else="">
                                <div class="text-center text-muted">
                                    <t t-if="not search">
                                        <h3 class="mt8">Marca no definida</h3>
                                        <p t-if="category">Marca no definida en categoria "<strong t-esc="category.display_name"/>".</p>
                                    </t>
                                    <t t-else="">
                                        <h3 class="mt8">No results</h3>
                                        <p>No results for "<strong t-esc='search'/>".</p>
                                    </t>
                                </div>
                            </t>
                        </div>
                    </div>
                    <div class="products_pager form-inline justify-content-center mt-3">
                        <t t-call="website.pager"/>
                    </div>
                </div>
                <div class="oe_structure mb32" id="oe_structure_website_sale_products_2"/>
            </div>
        </t>
    </template>

      <template id="wk_brands_item" name="brands  card" >
          <!-- <t t-set="product_href" t-value="keep(product.website_url, page=(pager['page']['num'] if pager['page']['num']&gt;1 else None))" /> -->

          <!-- <t t-set="combination_info" t-value="product._get_combination_info(only_template=True, add_qty=add_qty or 1, pricelist=pricelist)"/> -->

          <form  class="card oe_product_cart">
              <div class="card-body p-1 oe_product_image">
                  <!-- <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()" /> -->
                  <a t-att-href="keep('/product/brand/%s' % wk_brand.id, page=(pager['page']['num'] if pager['page']['num']&gt;1 else None))">
                      <span class="d-flex h-100 justify-content-center align-items-center" >
                        <img t-attf-src="/web/image/wk.product.brand/#{wk_brand.id}/image"
                          class="img img-fluid"/>
                        </span>

                      
                  </a>
              </div>
              <div class="card-body p-0 text-center o_wsale_product_information">
                  <div class="p-2 o_wsale_product_information_text">
                      <h6 class="o_wsale_products_item_title">
                          <a   t-att-href="keep('/product/brand/%s' % wk_brand.id, page=(pager['page']['num'] if pager['page']['num']&gt;1 else None), search=None)" t-att-content="wk_brand.name" t-field="wk_brand.name" />
                      </h6>
                      <div class="product_price" itemprop="offers" itemscope="itemscope" itemtype="http://schema.org/Offer">
                           <span t-esc="wk_brand.total_products" /> Products
                      </div>
                      
                        <div class="brand_description" itemprop="offers" itemscope="itemscope" itemtype="http://schema.org/Offer"/>
                  </div>
                  <div class="o_wsale_product_btn"/>
              </div>
          </form>
      </template>


