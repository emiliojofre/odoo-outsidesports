        <template id="brand_shop_now" inherit_id="website_product_brands.wk_brands_item" active="False" customize_show="True" name="Shop Now Button">
            <xpath expr="//div[hasclass('o_wsale_product_btn')]" position="after">
                <a t-att-href="keep('/product/brand/%s' % wk_brand.id)" class="btn btn-success mb-2" title="View Brand Products"> 
                    <span>Shop Now</span>
                </a>
            </xpath>
        </template>

        <template id="brand_description" inherit_id="website_product_brands.wk_brands_item" active="False" customize_show="True" name="Brand Description">
            <xpath expr="//div[hasclass('brand_description')]" position="after">
                <t t-if="wk_brand.description">
                    <span t-esc="wk_brand.description[:20]"/>
                    <a t-if="len(wk_brand.description) > 20" type="button" class="text-info" data-bs-toggle="modal" data-bs-target=".bd-example-modal-lg">.... Read more</a>

                    <div class="modal fade bd-example-modal-lg" tabindex="-1" role="dialog" aria-labelledby="myLargeModalLabel" aria-hidden="true">
                        <div class="modal-dialog modal-lg container">
                            <div class="modal-content" >
                                <div class="modal-header">
                                    <span class="display-4" style="color:#8B8B8B;">Información Marca</span>
                                </div>
                                <div class="description col-md-12">
                                    <span t-if="wk_brand.description" t-esc="wk_brand.description" />
                                    <br/>
                                    <br/>
                                    <span>Total <t t-esc="wk_brand.total_products"/> Products are available. </span>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Ok</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </xpath>
        </template>

        <template id="add_grid_or_list_option" inherit_id="website_product_brands.wk_product_brand_page" active="True" customize_show="True" name="Grid or List button">
            <xpath expr="//div[hasclass('products_pager')]/t[@t-call][last()]" position="after">
                <t t-set="_activeClasses">border-primary</t>
                <div t-attf-class="o_wsale_apply_layout btn-group ms-3 {{_classes}}" t-att-data-active-classes="_activeClasses">
                    <input type="radio" class="btn-check" name="wsale_products_layout" id="o_wsale_apply_grid"  t-att-checked="'checked' if layout_mode != 'list' else None" value="grid"/>
                    <label t-attf-class="btn btn-{{navClass}} #{_activeClasses if layout_mode != 'list' else None} o_wsale_apply_grid" title="Grid" for="o_wsale_apply_grid">
                        <i class="fa fa-th-large"/>
                    </label>
                    <input type="radio" class="btn-check" name="wsale_products_layout" id="o_wsale_apply_list" t-att-checked="'checked' if layout_mode == 'list' else None" value="list"/>
                    <label t-attf-class="btn btn-{{navClass}} #{_activeClasses if layout_mode == 'list' else None} o_wsale_apply_list" title="List" for="o_wsale_apply_list">
                        <i class="oi oi-view-list"/>
                    </label>
                </div>
            </xpath>
        </template>

