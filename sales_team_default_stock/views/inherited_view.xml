<odoo>

    <record id="inherited_view_crm_team" model="ir.ui.view">
        <field name="name">inherited.crm.team</field>
        <field name="model">crm.team</field>
        <field name="inherit_id" ref="sales_team.crm_team_view_form" />
        <field name="arch" type="xml">
        <xpath expr="//page[@name='dashboard']" position="after">
            <page string="Routes" name="routes">
                <group string="Routes" >
                    <field name="route_id"/>
                </group>
            </page>
        </xpath>
        </field>
    </record>

    <record id="inherited_view_stock_location_route" model="ir.ui.view">
        <field name="name">inherited.stock.location.route</field>
        <field name="model">stock.location.route</field>
        <field name="inherit_id" ref="stock.stock_location_route_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='warehouse_ids']" position="after">
                <field name="salesteam_selectable" string="Sales Team"/>
            </xpath>
            <!-- <xpath expr="//field[@name='warehouse_selectable']/.." position="after">
                <group>
                    <field  name='salesteam_selectable' />
                </group>
            </xpath> -->
            
        </field>
    </record>
</odoo>