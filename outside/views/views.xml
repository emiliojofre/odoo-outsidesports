<odoo>
    <data>
        <record id="delivery_voucher_view" model="ir.ui.view">
            <field name="inherit_id" ref="stock.report_deliveryslip"/>
            <field name="arch" type="xml">
                <xpath expr="//table[@class='table table-condensed']/thead" position="replace">
                    <tr class="text-center">
                        <th>Fecha</th>
                        <th>Diario</th>
                    </tr>
                </xpath>
            </field>
        </record>

        <record model="ir.actions.act_window" id="delivery_voucher_window">
            <field name="name">Vale de entrega</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">stock.picking</field>
            <field name="view_mode">tree,form,qweb</field>
        </record>
    </data>
</odoo>
