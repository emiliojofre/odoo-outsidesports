<odoo>
    <record id="inherited_view_sale_order" model="ir.ui.view">
        <field name="name">inherited.sale.order</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
          <xpath expr="//field[@name='partner_id']" position="after">
              <field name="route_id"/>
          </xpath>
        </field>
    </record>

    <record id="inherited_view_stock_location_route" model="ir.ui.view">
        <field name="name">inherited.stock.location.route</field>
        <field name="model">stock.location.route</field>
        <field name="inherit_id" ref="stock.stock_location_route_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='warehouse_ids']" position="after">
                <field name="saleorder_selectable" string="Sale Order"/>
            </xpath>
        </field>
    </record>
</odoo>