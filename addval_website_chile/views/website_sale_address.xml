<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Formulario de checkout Chile B2C: autosuficiente.

        A proposito NO hereda de "addval_website_address.address_custom":
        en produccion/testing existen dos copias de esa vista (una
        generica y otra especifica del sitio "Outside Sports") y su
        resolucion resulto ambigua e inconsistente entre entornos,
        causando que nuestras modificaciones nunca se aplicaran (o, al
        forzar el reapunte, un error 500 porque las dos copias tienen
        estructuras distintas). Para eliminar esa ambiguedad, heredamos
        directamente de "website_sale.address" (nucleo de Odoo, una
        sola copia, sin ambiguedad posible) y construimos el formulario
        completo aqui mismo.

        Los ids (phone_display, phone_input, vat_input, city_id_select,
        city_input) coinciden a proposito con los que ya espera
        static/src/js/checkout_chile.js - ese JS no se toca.
    -->
    <template id="address_chile_rut_phone"
              inherit_id="website_sale.address"
              name="Chile B2C - Formulario de dirección (RUT, Teléfono, Comuna)">

        <form action="/shop/address" method="post" class="checkout_autoformat" position="replace">
            <form t-if="account_on_checkout != 'mandatory' or not is_public_user"
                  action="/shop/address" method="post" class="checkout_autoformat">
                <div class="row">
                    <div t-attf-class="mb-3 #{error.get('name') and 'o_has_error' or ''} col-lg-12 div_name">
                        <label class="col-form-label" for="name">Nombre *</label>
                        <input type="text" name="name"
                               t-attf-class="form-control #{error.get('name') and 'is-invalid' or ''}"
                               t-att-value="'name' in checkout and checkout['name']"/>
                    </div>
                    <div class="w-100"/>

                    <div t-attf-class="mb-3 #{error.get('email') and 'o_has_error' or ''} col-lg-6" id="div_email">
                        <label class="col-form-label" for="email">Email *</label>
                        <input type="email" name="email"
                               t-attf-class="form-control #{error.get('email') and 'is-invalid' or ''}"
                               t-att-value="'email' in checkout and checkout['email']"/>
                    </div>

                    <div t-attf-class="mb-3 #{error.get('phone') and 'o_has_error' or ''} col-lg-6" id="div_phone">
                        <label class="col-form-label" for="phone">Teléfono * (9 dígitos)</label>
                        <div class="input-group">
                            <span class="input-group-text">+56</span>
                            <input type="tel" id="phone_display"
                                   t-attf-class="form-control #{error.get('phone') and 'is-invalid' or ''}"
                                   inputmode="tel" maxlength="9" pattern="[0-9]{9}"
                                   placeholder="912345678"
                                   title="Ingresa 9 dígitos. Se agregará +56 automáticamente."
                                   t-att-value="'phone' in checkout and checkout['phone'] and checkout['phone'].replace('+56','') or ''"/>
                        </div>
                        <input type="hidden" name="phone" id="phone_input"
                               t-att-value="'phone' in checkout and checkout['phone'] or ''"/>
                    </div>

                    <div class="w-100"/>

                    <t t-set="vat_warning" t-value="'vat' in checkout and checkout['vat'] and not can_edit_vat"/>
                    <div t-attf-class="mb-3 #{error.get('company_name') and 'o_has_error' or ''} col-lg-6 mb-0">
                        <label class="col-form-label label-optional" for="company_name">Razón Social</label>
                        <input type="text" name="company_name"
                               t-attf-class="form-control #{error.get('company_name') and 'is-invalid' or ''}"
                               t-att-value="'commercial_company_name' in checkout and checkout['commercial_company_name'] or 'company_name' in checkout and checkout['company_name']"
                               t-att-readonly="'1' if vat_warning else None"/>
                    </div>
                    <div t-attf-class="mb-3 #{error.get('vat') and 'o_has_error' or ''} col-lg-6 div_vat mb-0">
                        <label class="col-form-label fw-bold" for="vat">RUT *</label>
                        <input type="text" name="vat" id="vat_input"
                               t-attf-class="form-control #{error.get('vat') and 'is-invalid' or ''}"
                               placeholder="12345678-9" required="required"
                               t-att-value="'vat' in checkout and checkout['vat']"
                               t-att-readonly="'1' if vat_warning else None"/>
                    </div>
                    <div t-if="vat_warning" class="col-12 mb-1">
                        <small class="form-text text-muted">No es posible modificar la Razón Social o el RUT una vez emitidos documentos para tu cuenta. Contáctanos directamente para esta operación.</small>
                    </div>

                    <div class="w-100"/>

                    <div t-attf-class="mb-3 #{error.get('country_id') and 'o_has_error' or ''} col-lg-6 div_country">
                        <label class="col-form-label" for="country_id">País *</label>
                        <select id="country_id" name="country_id"
                                t-attf-class="form-select #{error.get('country_id') and 'is-invalid' or ''}"
                                t-att-mode="mode[1]">
                            <option value="">País...</option>
                            <t t-foreach="countries" t-as="c">
                                <option t-att-value="c.id" t-att-selected="c.id == (country and country.id or -1)">
                                    <t t-esc="c.name"/>
                                </option>
                            </t>
                        </select>
                    </div>
                    <div t-attf-class="mb-3 #{error.get('state_id') and 'o_has_error' or ''} col-lg-6 div_state"
                         t-att-style="(not country or not country.state_ids) and 'display: none'">
                        <label class="col-form-label fw-bold" for="state_id">Región *</label>
                        <select id="state_id" name="state_id"
                                t-attf-class="form-select #{error.get('state_id') and 'is-invalid' or ''}">
                            <option value="">Región...</option>
                            <t t-foreach="country_states" t-as="s">
                                <option t-att-value="s.id"
                                        t-att-selected="s.id == ('state_id' in checkout and country and checkout['state_id'] != '' and int(checkout['state_id']))">
                                    <t t-esc="s.name"/>
                                </option>
                            </t>
                        </select>
                    </div>

                    <div class="w-100"/>

                    <div t-attf-class="mb-3 #{error.get('city_id') and 'o_has_error' or ''} col-md-8">
                        <label class="col-form-label" for="city_id">Comuna *</label>
                        <select id="city_id_select" name="city_id"
                                t-attf-class="form-select #{error.get('city_id') and 'is-invalid' or ''}">
                            <option value="">Comuna...</option>
                            <t t-foreach="country_state_cities" t-as="s">
                                <option t-att-value="s.id"
                                        t-att-selected="s.id == ('city_id' in checkout and country and state and checkout['city_id'] != '' and int(checkout['city_id']))">
                                    <t t-esc="s.name"/>
                                </option>
                            </t>
                        </select>
                        <input id="city_input" type="text" name="city"
                               t-attf-class="form-control #{error.get('city') and 'is-invalid' or ''}"
                               t-att-value="'city' in checkout and checkout['city']"
                               t-att-required="false" style="display: none"/>
                    </div>
                    <div t-attf-class="mb-3 #{error.get('zip') and 'o_has_error' or ''} col-md-4 div_zip">
                        <label class="col-form-label" for="zip">Código Postal</label>
                        <input type="text" name="zip"
                               t-attf-class="form-control #{error.get('zip') and 'is-invalid' or ''}"
                               t-att-value="'zip' in checkout and checkout['zip']"/>
                    </div>

                    <div class="w-100"/>

                    <div t-attf-class="mb-3 #{error.get('street') and 'o_has_error' or ''} col-lg-12 div_street">
                        <label class="col-form-label" for="street">Dirección *</label>
                        <input type="text" name="street"
                               t-attf-class="form-control #{error.get('street') and 'is-invalid' or ''}"
                               t-att-value="'street' in checkout and checkout['street']"/>
                    </div>
                    <div t-attf-class="mb-3 #{error.get('street2') and 'o_has_error' or ''} col-lg-12 div_street2">
                        <label class="col-form-label label-optional" for="street2">Dirección 2</label>
                        <input type="text" name="street2"
                               t-attf-class="form-control #{error.get('street2') and 'is-invalid' or ''}"
                               t-att-value="'street2' in checkout and checkout['street2']"/>
                    </div>

                    <div class="w-100"/>

                    <t t-if="mode == ('new', 'billing') and not only_services">
                        <div class="col-lg-12">
                            <div class="checkbox">
                                <label>
                                    <input type="checkbox" id="shipping_use_same" class="mr8" name="use_same" value="1" checked="checked"/>
                                    Enviar a la misma dirección
                                    <span class="ship_to_other text-muted" style="display: none">&#160;(<i>Tu dirección de envío se pedirá más adelante</i>) </span>
                                </label>
                            </div>
                        </div>
                    </t>

                    <p class="text-muted small mt-2 mb-3"><em>* Campo obligatorio</em></p>
                </div>

                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()" t-nocache="El token csrf siempre debe estar actualizado."/>
                <input type="hidden" name="submitted" value="1"/>
                <input type="hidden" name="partner_id" t-att-value="partner_id or '0'"/>
                <input type="hidden" name="callback" t-att-value="callback"/>
                <input type="hidden" name="field_required" t-att-value="'phone,name,vat'"/>

                <div class="d-flex justify-content-between">
                    <a role="button" t-att-href="mode == ('new', 'billing') and '/shop/cart' or '/shop/checkout'" class="btn btn-secondary mb32">
                        <i class="fa fa-chevron-left"/>
                        <span>Volver</span>
                    </a>
                    <a role="button" href="#" class="btn btn-primary mb32 a-submit a-submit-disable a-submit-loading">
                        <span>Siguiente</span>
                        <i class="fa fa-chevron-right"/>
                    </a>
                </div>
            </form>
        </form>
    </template>

    <record id="address_chile_rut_phone" model="ir.ui.view">
        <field name="website_id" search="[('name','=','OUTSIDE SPORTS B2C')]" model="website"/>
    </record>

</odoo>
