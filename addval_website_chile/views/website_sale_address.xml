<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Override del formulario de checkout de addval_website_address:
        - Renombra VAT → RUT, obligatorio
        - Agrega id="vat_input" y id="phone_input" para JS
        - Actualiza field_required para incluir vat
    -->
    <template id="address_chile_rut_phone"
              inherit_id="addval_website_address.address_custom"
              name="Chile - RUT y Teléfono">

        <!-- Agregar id al input de teléfono para JS -->
        <xpath expr="//input[@name='phone']" position="attributes">
            <attribute name="id">phone_input</attribute>
            <attribute name="placeholder">+56912345678</attribute>
            <attribute name="title">Ingresa tu número chileno, ej: +56912345678 o 912345678</attribute>
        </xpath>

        <!-- Cambiar label VAT → RUT -->
        <xpath expr="//label[@for='vat']" position="replace">
            <label class="col-form-label fw-bold" for="vat">RUT *(Campo obligatorio)</label>
        </xpath>

        <!-- Agregar id, required y placeholder al input vat -->
        <xpath expr="//input[@name='vat']" position="attributes">
            <attribute name="id">vat_input</attribute>
            <attribute name="required">required</attribute>
            <attribute name="placeholder">12345678-9</attribute>
        </xpath>

        <!-- Actualizar field_required para incluir vat -->
        <xpath expr="//input[@name='field_required']" position="attributes">
            <attribute name="t-att-value">'phone,name,vat'</attribute>
        </xpath>

    </template>
</odoo>
