<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Todos los templates aplican SOLO al sitio B2C.
        El website_id se asigna via <record> después de crear cada template,
        ya que en Odoo 16 el atributo website_id requiere un xmlid, no un int.
    -->

    <!-- ================================================================
         1. Formulario de checkout: labels, RUT, teléfono, pie de página
         ================================================================ -->
    <template id="address_chile_rut_phone"
              inherit_id="addval_website_address.address_custom"
              name="Chile B2C - RUT, Teléfono y Labels">

        <xpath expr="//label[@for='name']" position="replace">
            <label class="col-form-label" for="name">Nombre *</label>
        </xpath>
        <xpath expr="//label[@for='email']" position="replace">
            <label t-attf-class="col-form-label #{mode[1] == 'shipping' and 'label-optional' or ''}" for="email">Email *</label>
        </xpath>
        <xpath expr="//label[@for='phone']" position="replace">
            <label class="col-form-label" for="phone">Teléfono *</label>
        </xpath>
        <xpath expr="//input[@name='phone']" position="attributes">
            <attribute name="id">phone_input</attribute>
            <attribute name="placeholder">912345678</attribute>
            <attribute name="title">Ingresa 9 dígitos. Se agregará +56 automáticamente.</attribute>
            <attribute name="maxlength">9</attribute>
            <attribute name="pattern">[0-9]{9}</attribute>
        </xpath>
        <xpath expr="//label[@for='country_id']" position="replace">
            <label class="col-form-label" for="country_id">País *</label>
        </xpath>
        <xpath expr="//label[@for='state_id']" position="replace">
            <label class="col-form-label fw-bold" for="state_id">Región *</label>
        </xpath>
        <xpath expr="//label[@for='city_id']" position="replace">
            <label class="col-form-label" for="city_id">Comuna *</label>
        </xpath>
        <xpath expr="//label[@for='street']" position="replace">
            <label class="col-form-label" for="street">Dirección *</label>
        </xpath>
        <xpath expr="//label[@for='vat']" position="replace">
            <label class="col-form-label fw-bold" for="vat">RUT *</label>
        </xpath>
        <xpath expr="//input[@name='vat']" position="attributes">
            <attribute name="id">vat_input</attribute>
            <attribute name="required">required</attribute>
            <attribute name="placeholder">12345678-9</attribute>
        </xpath>
        <xpath expr="//div[hasclass('d-flex') and hasclass('justify-content-between')]" position="before">
            <p class="text-muted small mt-2 mb-3"><em>* Campo obligatorio</em></p>
        </xpath>
        <xpath expr="//input[@name='field_required']" position="attributes">
            <attribute name="t-att-value">'phone,name,vat'</attribute>
        </xpath>
    </template>

    <!-- Asignar website_id B2C al template de checkout -->
    <record id="address_chile_rut_phone" model="ir.ui.view">
        <field name="website_id" search="[('name','=','OUTSIDE SPORTS B2C')]" model="website"/>
    </record>

    <!-- ================================================================
         2. Catálogo: sacar PVP — solo B2C
         ================================================================ -->
    <template id="outside_hide_pvp_catalog"
              inherit_id="eq_website_default_code.products_item_default_codes"
              name="Chile B2C - Ocultar PVP en catálogo">
        <xpath expr="//div[span[hasclass('pvp')]]" position="replace"/>
    </template>

    <record id="outside_hide_pvp_catalog" model="ir.ui.view">
        <field name="website_id" search="[('name','=','OUTSIDE SPORTS B2C')]" model="website"/>
    </record>

    <!-- ================================================================
         3. Ficha de producto: sacar PVP — solo B2C
         ================================================================ -->
    <template id="outside_hide_pvp_product"
              inherit_id="eq_website_default_code.product_default_codes"
              name="Chile B2C - Ocultar PVP en ficha">
        <xpath expr="//div[span[hasclass('pvp')]]" position="replace"/>
    </template>

    <record id="outside_hide_pvp_product" model="ir.ui.view">
        <field name="website_id" search="[('name','=','OUTSIDE SPORTS B2C')]" model="website"/>
    </record>

    <!-- ================================================================
         4. Tax indication activo — solo B2C
         ================================================================ -->
    <template id="outside_tax_indication_b2c"
              inherit_id="website_sale.tax_indication"
              name="Chile B2C - Tax indication activo"
              active="True">
    </template>

    <record id="outside_tax_indication_b2c" model="ir.ui.view">
        <field name="website_id" search="[('name','=','OUTSIDE SPORTS B2C')]" model="website"/>
    </record>

</odoo>
