<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_sale_approval_route" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.sale.approval.route</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="25"/>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='sale_config_online_confirmation_sign']" position="before">
                <div class="col-12 col-lg-6 o_setting_box" id="use_approval_route_sale">
                    <div class="o_setting_left_pane"/>
                    <div class="o_setting_right_pane">
                        <label for="use_approval_route_sale"/>
                        <span class="fa fa-lg fa-building-o" title="Values set here are company-specific."
                              aria-label="Values set here are company-specific." groups="base.group_multi_company"
                              role="img"/>
                        <div class="text-muted">
                            Use Dynamic Approval Route for Sale Orders
                        </div>
                        <div class="content-group">
                            <div class="mt16">
                                <field name="use_approval_route_sale" class="o_light_label" widget="radio"/>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
