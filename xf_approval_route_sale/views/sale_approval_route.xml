<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data> <!--  noupdate="1" -->
        <record id="sale_order_approval_form" model="ir.ui.view">
            <field name="name">sale.order.approval.form</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="model">sale.order</field>
            <field name="arch" type="xml">
                <button name="action_cancel" position="attributes">
                    <attribute name="attrs">
                        {'invisible':
                        ['|', ('state', 'not in', ['draft', 'sent', 'to approve', 'sale']), ('id', '=', False)]}
                    </attribute>
                </button>
                <button name="action_cancel" position="before">
                    <button name="button_approve" type="object" states='to approve' string="Approve Order"
                            class="oe_highlight" attrs="{'invisible':['|', ('is_current_approver', '!=', True)]}"/>
                </button>
                <field name="payment_term_id" position="after">
                    <field name="use_approval_route" invisible="True"/>
                    <field name="approval_route_id"
                           attrs="{'invisible':[('use_approval_route', '=', 'no')], 'required':[('use_approval_route', '=', 'required')]}"/>
                </field>
                <notebook position="inside">
                    <page name="approval_route" string="Approval Route"
                          attrs="{'invisible':['|', ('state', 'in', ['draft', 'sent']), ('approval_route_id', '=', False)]}">
                        <field name="approval_route_stage_ids"/>
                        <field name="is_current_approver" invisible="True"/>
                    </page>
                </notebook>
            </field>
        </record>
    </data>
</odoo>