<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
      <record id="sale_order_hes" model="ir.ui.view">
        <field name="name">sale.order.hes</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <field name="client_order_ref" position="before">
                <field name="oc_hes_required" string="OC y HES requeridos"/>
            </field>
            <field name="client_order_date" position="after">
                <field name="client_hes_ref" string="Referencia HES cliente" attrs="{'required': [('is_subscription', '=', False), ('oc_hes_required', '=', True)]}"/>
                <field name="cliente_hes_date" string="Fecha HES cliente" attrs="{'required': [('is_subscription', '=', False), ('oc_hes_required', '=', True)]}"/>
            </field>
            <field name="client_order_ref" position="attributes">
                <attribute name="attrs">{'required': [('is_subscription', '=', False), ('oc_hes_required', '=', True)]}</attribute>
            </field>
            <field name="client_order_date" position="attributes">
                <attribute name="attrs">{'required': [('is_subscription', '=', False), ('oc_hes_required', '=', True)]}</attribute>
            </field>
        </field>
      </record>
    </data>
  </odoo>