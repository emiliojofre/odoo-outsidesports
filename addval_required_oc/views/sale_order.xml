<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
      <record id="sale_order_hes" model="ir.ui.view">
        <field name="name">sale.order.hes</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <field name="payment_term_id" position="after">
                <field name="oc_hes_required" string="Referencia requerida"/>
            </field>
            <xpath expr="//notebook[1]" position="inside">
                <page name="references" string="Referencias">
                    <field name="reference_ids" widget="one2many" colspan="3" nolabel="1" mode="tree">
                        <tree string="Cuentas" editable="top">
                            <field name="reference_number"/>
                            <field name="reference_date"/>
                            <field name="reference_doc_type_id"/>
                        </tree>
                    </field>
                </page>
            </xpath>
            <field name="client_order_ref" position="attributes">
                <attribute name="attrs">{'invisible': True}</attribute>
            </field>
            <field name="client_order_date" position="attributes">
                <attribute name="attrs">{'invisible': True}</attribute>
            </field>
        </field>
      </record>
    </data>
  </odoo>