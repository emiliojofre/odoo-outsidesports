<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="alas_express_label_wizard_form" model="ir.ui.view">
        <field name="name">alas.express.label.wizard.form</field>
        <field name="model">alas.express.label.wizard</field>
        <field name="arch" type="xml">
            <form string="Alas Express - Acciones Masivas">
                <sheet>
                    <div class="oe_title">
                        <h1>Alas Express</h1>
                    </div>

                    <group>
                        <field name="action_type" widget="radio"/>
                    </group>

                    <group string="Albaranes seleccionados">
                        <field name="picking_ids" nolabel="1">
                            <tree editable="bottom">
                                <field name="name"/>
                                <field name="partner_id"/>
                                <field name="carrier_id"/>
                                <field name="alas_delivery_order_id"/>
                                <field name="alas_status"/>
                                <field name="state"/>
                            </tree>
                        </field>
                    </group>

                    <group string="Resultado"
                           attrs="{'invisible': [('result_log', '=', False)]}">
                        <field name="result_log" nolabel="1" readonly="1"
                               widget="text" style="font-family: monospace; font-size: 12px;"/>
                    </group>

                </sheet>
                <footer>
                    <button name="action_execute"
                            string="Ejecutar"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cerrar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_alas_express_label_wizard" model="ir.actions.act_window">
        <field name="name">Alas Express - Acciones</field>
        <field name="res_model">alas.express.label.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'dialog_size': 'extra-large'}</field>
    </record>

</odoo>
