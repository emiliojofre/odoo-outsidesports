<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_alas_express" model="ir.ui.view">
        <field name="name">res.config.settings.view.alas.express</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='inventory']" position="after">
                <div id="alas_express_settings">
                    <h2>Alas Express</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label for="alas_express_env"/>
                                <div class="text-muted">
                                    Entorno de operación de la API de Alas Express.
                                    La API solo opera en producción.
                                </div>
                                <div class="mt8">
                                    <field name="alas_express_env" readonly="1"/>
                                </div>
                                <div class="mt8">
                                    <a href="/odoo/inventory/configuration/delivery-methods"
                                       class="btn btn-secondary btn-sm">
                                        ⚙️ Configurar métodos de envío Alas Express
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
