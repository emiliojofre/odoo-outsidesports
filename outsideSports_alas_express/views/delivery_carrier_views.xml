<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Hereda la vista del carrier para agregar tab de Alas Express -->
    <record id="delivery_carrier_form_alas_express" model="ir.ui.view">
        <field name="name">delivery.carrier.form.alas.express</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">

            <xpath expr="//page[@name='destination']" position="before">
                <page name="alas_express_config"
                      string="Alas Express"
                      attrs="{'invisible': [('delivery_type', '!=', 'alas_express')]}">

                    <group string="Credenciales API">
                        <group>
                            <field name="alas_api_key"
                                   password="True"
                                   placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"/>
                            <field name="alas_partner"
                                   placeholder="Ej: OutsideSports"/>
                            <field name="alas_sender_code"
                                   placeholder="Ej: 76543210-2"/>
                        </group>
                        <group>
                            <field name="alas_sender_location"
                                   placeholder="Código de bodega (opcional)"/>
                            <field name="alas_lob_type"/>
                        </group>
                    </group>

                    <group string="Opciones de Envío">
                        <group>
                            <field name="alas_dispatch_labels"/>
                            <field name="alas_labels_sync"/>
                        </group>
                        <group>
                            <field name="alas_ampm_service"/>
                            <field name="alas_big_ticket"/>
                            <field name="alas_add_insurance"/>
                        </group>
                    </group>

                    <group string="Tarifas por Región">
                        <div class="alert alert-warning" role="alert" colspan="2">
                            La API de Alas Express no entrega cotización de envío.
                            Defina aquí el precio a cobrar por cada región de Chile.
                            El checkout usa la región del destinatario
                            (<code>partner_shipping_id.state_id</code>).
                        </div>
                        <group>
                            <field name="alas_default_price"/>
                            <field name="alas_require_region_rate"/>
                        </group>
                        <group>
                            <button name="action_alas_load_chile_regions"
                                    type="object"
                                    string="Cargar regiones de Chile"
                                    class="btn-secondary"
                                    attrs="{'invisible': [('id', '=', False)]}"/>
                        </group>
                    </group>
                    <field name="alas_region_rate_ids"
                           nolabel="1"
                           attrs="{'invisible': [('id', '=', False)]}">
                        <tree editable="bottom">
                            <field name="state_id"/>
                            <field name="price"/>
                            <field name="currency_id" optional="hide"/>
                        </tree>
                    </field>

                    <group string="Información de la API">
                        <div class="alert alert-info" role="alert">
                            <strong>Autenticación:</strong> Header <code>x-alas-ce0-api-key</code><br/>
                            <strong>Base URL:</strong> <code>https://ws.alasxpress.com/api</code><br/>
                            <strong>Documentación:</strong>
                            <a href="https://ws.alasxpress.com/api/swagger.json" target="_blank">
                                swagger.json
                            </a>
                        </div>
                    </group>

                </page>
            </xpath>

        </field>
    </record>

    <!-- Vista árbol de tarifas (para abrir desde otras acciones si se requiere) -->
    <record id="view_alas_express_region_rate_tree" model="ir.ui.view">
        <field name="name">alas.express.region.rate.tree</field>
        <field name="model">alas.express.region.rate</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="carrier_id" optional="hide"/>
                <field name="state_id"/>
                <field name="price"/>
                <field name="currency_id"/>
            </tree>
        </field>
    </record>

    <!-- Acción para crear carrier Alas Express directamente -->
    <record id="action_delivery_carrier_alas_express" model="ir.actions.act_window">
        <field name="name">Alas Express</field>
        <field name="res_model">delivery.carrier</field>
        <field name="view_mode">form</field>
        <field name="context">{'default_delivery_type': 'alas_express'}</field>
    </record>

</odoo>
