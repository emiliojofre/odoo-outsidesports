<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_xf_approval_route_base" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.approval.route.base</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="50"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="Approval Settings" string="Approval Settings"
                     data-key="xf_approval_route_base" groups="xf_approval_route_base.group_approval_route_manager">
                    <div id="xf_approval_route_base">
                        <h2>Roles</h2>
                        <div class="row mt16 o_settings_container" name="xf_approval_route_base_roles">
                            <div class="col-xs-12 col-md-6 o_setting_box" id="xf_approval_route_base_roles_setting">
                                <div class="o_setting_right_pane">
                                    <div class="w-50">
                                        <field name="approval_role_count" class="w-auto ps-1 fw-bold"/>
                                        <span class="o_form_label"
                                              attrs="{'invisible':[('approval_role_count', '&gt;', '1')]}">
                                            Predefined Approval Role
                                        </span>
                                        <span class="o_form_label"
                                              attrs="{'invisible':[('approval_role_count', '&lt;=', '1')]}">
                                            Predefined Approval Roles
                                        </span>
                                    </div>
                                    <div class="mt8">
                                        <button name="%(xf_approval_route_base.approval_role_form_act_window)d"
                                                icon="fa-arrow-right" type="action" string="Add Approval Role"
                                                class="btn-link"/>
                                    </div>
                                    <div class="mt8">
                                        <button name="%(xf_approval_route_base.approval_role_act_window)d"
                                                icon="fa-arrow-right" type="action" string="Manage Approval Roles"
                                                class="btn-link"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <h2>Routes</h2>
                        <div class="row mt16 o_settings_container" name="xf_approval_route_base_routes">
                            <div class="col-xs-12 col-md-6 o_setting_box" id="xf_approval_route_base_routes_setting">
                                <div class="o_setting_right_pane">
                                    <div class="w-50">
                                        <field name="approval_route_count" class="w-auto ps-1 fw-bold"/>
                                        <span class="o_form_label"
                                              attrs="{'invisible':[('approval_route_count', '&gt;', '1')]}">
                                            Approval Route
                                        </span>
                                        <span class="o_form_label"
                                              attrs="{'invisible':[('approval_route_count', '&lt;=', '1')]}">
                                            Approval Routes
                                        </span>
                                    </div>
                                    <div class="mt8">
                                        <button name="%(xf_approval_route_base.approval_route_form_act_window)d"
                                                icon="fa-arrow-right" type="action" string="Add Approval Route"
                                                class="btn-link"/>
                                    </div>
                                    <div class="mt8">
                                        <button name="%(xf_approval_route_base.approval_route_act_window)d"
                                                icon="fa-arrow-right" type="action" string="Manage Approval Routes"
                                                class="btn-link"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

    <record id="action_approval_route_base_configuration" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module' : 'xf_approval_route_base'}</field>
    </record>

</odoo>
