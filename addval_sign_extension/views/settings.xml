<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="res_config_settings_sign_request" model="ir.ui.view">
        <field name="name">res.config.settings.sign.request</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sign.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='sign']" position="inside">
                <h3>Configuraciones Correos</h3>
                <div class="col-12 col-lg-6 o_setting_box">
                    <div class="o_setting_right_pane">
                        <div>
                            <label
                                string="Correo Solicitud de Firma"
                                for="sign_request_mail"/>
                            <div class="text-muted">
                                Correo Advertencia
                            </div>
                            <div class="content-group mt16">
                                <field
                                    name="sign_request_mail"
                                    colspan="4"
                                    nolabel="1"
                                />
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
